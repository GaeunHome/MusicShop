@{
    ViewData["Title"] = "後台管理";
    ViewData["PageId"] = "admin-index";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container mt-4">
    <h3 class="mb-4">📊 後台管理總覽</h3>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-primary">
                <div class="card-body">
                    <div class="fs-1">🎵</div>
                    <h5 class="card-title mt-2">商品數量</h5>
                    <p class="display-6 fw-bold text-primary">@ViewBag.AlbumCount</p>
                    <a asp-action="Albums" class="btn btn-sm btn-outline-primary">管理商品</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body">
                    <div class="fs-1">🏷️</div>
                    <h5 class="card-title mt-2">分類數量</h5>
                    <p class="display-6 fw-bold text-success">@ViewBag.CategoryCount</p>
                    <div class="mt-2">
                        <a asp-action="Categories" class="btn btn-sm btn-outline-success">管理分類</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-warning">
                <div class="card-body">
                    <div class="fs-1">📦</div>
                    <h5 class="card-title mt-2">訂單數量</h5>
                    <p class="display-6 fw-bold text-warning">@ViewBag.OrderCount</p>
                    <a asp-action="Orders" class="btn btn-sm btn-outline-warning">管理訂單</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-info">
                <div class="card-body">
                    <div class="fs-1">👥</div>
                    <h5 class="card-title mt-2">會員數量</h5>
                    <p class="display-6 fw-bold text-info">@ViewBag.UserCount</p>
                    <a asp-action="Users" class="btn btn-sm btn-outline-info">管理使用者</a>
                </div>
            </div>
        </div>
    </div>

    <!-- 銷售統計 -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="fs-1 me-3">💰</div>
                        <div>
                            <h5 class="card-title mb-1">總銷售額</h5>
                            <p class="display-6 fw-bold text-danger mb-0">NT$ @ViewBag.TotalSales?.ToString("N0")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-secondary">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="fs-1 me-3">⏳</div>
                        <div>
                            <h5 class="card-title mb-1">待處理訂單</h5>
                            <p class="display-6 fw-bold text-secondary mb-0">@ViewBag.PendingOrderCount</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 快速操作 -->
    <h5 class="mb-3">⚡ 快速操作</h5>
    <div class="row g-3">
        <div class="col-md-3">
            <a asp-action="AlbumCreate" class="btn btn-primary w-100 py-3">
                <i class="bi bi-plus-circle"></i> 新增商品
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Categories" class="btn btn-success w-100 py-3">
                <i class="bi bi-folder-plus"></i> 分類管理
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Orders" class="btn btn-warning w-100 py-3">
                <i class="bi bi-list-check"></i> 查看訂單
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Users" class="btn btn-info w-100 py-3">
                <i class="bi bi-people"></i> 管理使用者
            </a>
        </div>
    </div>

    <!-- 管理選單 -->
    <div class="mt-5">
        <h5 class="mb-3">🗂️ 管理選單</h5>
        <div class="list-group">
            <a asp-action="Albums" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span><i class="bi bi-music-note-list"></i> 商品管理</span>
                <span class="badge bg-primary rounded-pill">@ViewBag.AlbumCount</span>
            </a>
            <a asp-action="Categories" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span><i class="bi bi-tags"></i> 分類管理</span>
                <span class="badge bg-success rounded-pill">@ViewBag.CategoryCount</span>
            </a>
            <a asp-action="Orders" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span><i class="bi bi-box-seam"></i> 訂單管理</span>
                <span class="badge bg-warning text-dark rounded-pill">@ViewBag.OrderCount</span>
            </a>
            <a asp-action="Users" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person-badge"></i> 使用者管理</span>
                <span class="badge bg-info rounded-pill">@ViewBag.UserCount</span>
            </a>
        </div>
    </div>
</div>