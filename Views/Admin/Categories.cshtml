@{
    ViewData["Title"] = "分類管理";
    var artistCategories = ViewBag.ArtistCategories as IEnumerable<MusicShop.Models.ArtistCategory>;
    var parentCategories = ViewBag.ParentCategories as IEnumerable<MusicShop.Models.ProductType>;
    var categoryTree = ViewBag.CategoryTree as Dictionary<MusicShop.Models.ProductType, IEnumerable<MusicShop.Models.ProductType>>;
}

<div class="container mt-4">
    <h3 class="mb-4">🏷️ 分類管理</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- 藝人分類 -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">👥 藝人分類</h5>
            <a asp-action="ArtistCategoryCreate" class="btn btn-light btn-sm">➕ 新增藝人分類</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>名稱</th>
                            <th>描述</th>
                            <th>排序</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (artistCategories != null && artistCategories.Any())
                        {
                            @foreach (var category in artistCategories.OrderBy(c => c.DisplayOrder))
                            {
                                <tr>
                                    <td>@category.Id</td>
                                    <td class="fw-bold">@category.Name</td>
                                    <td>@category.Description</td>
                                    <td><span class="badge bg-secondary">@category.DisplayOrder</span></td>
                                    <td>
                                        <a asp-action="ArtistCategoryEdit" asp-route-id="@category.Id"
                                           class="btn btn-sm btn-outline-primary">編輯</a>
                                        <form asp-action="ArtistCategoryDelete" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@category.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('確定要刪除「@category.Name」嗎？')">刪除</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">目前沒有藝人分類</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 商品類型（階層式） -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">📦 商品類型（階層式）</h5>
            <a asp-action="ProductTypeCreate" class="btn btn-light btn-sm">➕ 新增商品類型</a>
        </div>
        <div class="card-body p-4">
            @if (categoryTree != null && categoryTree.Any())
            {
                <div class="row g-4">
                    @foreach (var parent in categoryTree.Keys.OrderBy(k => k.DisplayOrder))
                    {
                        <div class="col-md-6">
                            <div class="card border-success h-100">
                                <!-- 父分類標題 -->
                                <div class="card-header bg-success bg-opacity-10 border-bottom border-success">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h5 class="mb-1 text-success">
                                                <i class="bi bi-folder2-open"></i> @parent.Name
                                            </h5>
                                            @if (!string.IsNullOrEmpty(parent.Description))
                                            {
                                                <small class="text-muted">@parent.Description</small>
                                            }
                                            <div class="mt-1">
                                                <span class="badge bg-success">父分類</span>
                                                <span class="badge bg-secondary ms-1">排序: @parent.DisplayOrder</span>
                                                <span class="badge bg-info ms-1">ID: @parent.Id</span>
                                            </div>
                                        </div>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-success dropdown-toggle" type="button"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                操作
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li>
                                                    <a class="dropdown-item" asp-action="ProductTypeEdit" asp-route-id="@parent.Id">
                                                        <i class="bi bi-pencil"></i> 編輯父分類
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="ProductTypeDelete" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@parent.Id" />
                                                        <button type="submit" class="dropdown-item text-danger"
                                                                onclick="return confirm('確定要刪除「@parent.Name」嗎？此操作會同時刪除所有子分類！')">
                                                            <i class="bi bi-trash"></i> 刪除父分類
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <!-- 子分類列表 -->
                                <div class="card-body p-0">
                                    @if (categoryTree[parent].Any())
                                    {
                                        <div class="list-group list-group-flush">
                                            @foreach (var child in categoryTree[parent].OrderBy(c => c.DisplayOrder))
                                            {
                                                <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                                    <div class="flex-grow-1 me-3">
                                                        <div class="d-flex align-items-center mb-1">
                                                            <i class="bi bi-file-earmark text-secondary me-2" style="font-size: 1.1rem;"></i>
                                                            <strong class="me-2">@child.Name</strong>
                                                            <span class="badge bg-secondary" style="font-size: 0.75rem;">排序: @child.DisplayOrder</span>
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(child.Description))
                                                        {
                                                            <div class="text-muted small ms-4">@child.Description</div>
                                                        }
                                                    </div>
                                                    <div class="d-flex gap-2 flex-shrink-0">
                                                        <a asp-action="ProductTypeEdit" asp-route-id="@child.Id"
                                                           class="btn btn-sm btn-outline-primary" title="編輯">
                                                            <i class="bi bi-pencil me-1"></i>編輯
                                                        </a>
                                                        <form asp-action="ProductTypeDelete" method="post" class="d-inline">
                                                            <input type="hidden" name="id" value="@child.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                                                    onclick="return confirm('確定要刪除「@child.Name」嗎？')">
                                                                <i class="bi bi-trash me-1"></i>刪除
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                            <p class="mt-3 mb-3">此父分類下尚無子分類</p>
                                            <a asp-action="ProductTypeCreate" class="btn btn-sm btn-success">
                                                <i class="bi bi-plus-circle"></i> 新增子分類
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-folder-x" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">目前沒有商品類型</p>
                </div>
            }
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary mt-3">← 返回後台</a>
</div>
