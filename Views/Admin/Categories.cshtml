@model IEnumerable<MusicShop.Models.Category>
@{
    ViewData["Title"] = "分類管理";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>🏷️ 分類管理</h3>
        <a asp-action="CategoryCreate" class="btn btn-success">➕ 新增分類</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>分類名稱</th>
                <th>專輯數量</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Id</td>
                    <td class="fw-bold">@cat.Name</td>
                    <td><span class="badge bg-primary">@cat.Albums.Count 張</span></td>
                    <td>
                        <a asp-action="CategoryEdit" asp-route-id="@cat.Id"
                           class="btn btn-sm btn-outline-primary">編輯</a>
                        <form asp-action="CategoryDelete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@cat.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('確定要刪除「@cat.Name」分類嗎？')">刪除</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-outline-secondary mt-3">← 返回後台</a>
</div>