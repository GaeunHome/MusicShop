@model MusicShop.Models.Album
@{
    ViewData["Title"] = "編輯商品";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">✏️ 編輯商品</div>
                <div class="card-body">
                    <form asp-action="AlbumEdit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">商品名稱</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ArtistId" class="form-label">藝人/歌手</label>
                            <select asp-for="ArtistId" asp-items="ViewBag.Artists" class="form-select">
                                <option value="">請選擇藝人</option>
                            </select>
                            <span asp-validation-for="ArtistId" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ArtistCategoryId" class="form-label">藝人分類</label>
                                <select asp-for="ArtistCategoryId" asp-items="ViewBag.ArtistCategories" class="form-select">
                                    <option value="">請選擇藝人分類</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="ParentCategorySelect" class="form-label">商品大分類</label>
                                <select id="ParentCategorySelect" asp-items="ViewBag.ParentCategories" class="form-select">
                                    <option value="">請先選擇大分類</option>
                                </select>
                                <small class="text-muted">選擇後會顯示對應的子分類</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ProductTypeId" class="form-label">商品類型（子分類）</label>
                            <select asp-for="ProductTypeId" id="ProductTypeSelect" class="form-select">
                                <option value="">請先選擇大分類</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">描述</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label">價格</label>
                                <input asp-for="Price" class="form-control" type="number" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Stock" class="form-label">庫存</label>
                                <input asp-for="Stock" class="form-control" type="number" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CoverImageUrl" class="form-label">封面圖片網址（選填）</label>
                            <input asp-for="CoverImageUrl" class="form-control" />
                            <small class="text-muted">範例：/images/albums/album1.jpg</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="DescriptionImageUrl" class="form-label">商品介紹圖片網址（選填）</label>
                            <input asp-for="DescriptionImageUrl" class="form-control" />
                            <small class="text-muted">範例：/images/albums/album6.jpg（用於顯示詳細的商品組成內容、尺寸等）</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Albums" class="btn btn-outline-secondary">← 取消</a>
                            <button type="submit" class="btn btn-primary">儲存變更</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        var selectedProductTypeId = @Html.Raw(ViewBag.SelectedProductTypeId ?? "null");

        $(document).ready(function() {
            // 載入子分類的函數
            function loadChildCategories(parentId, selectedId) {
                var productTypeSelect = $('#ProductTypeSelect');

                productTypeSelect.html('<option value="">載入中...</option>');
                productTypeSelect.prop('disabled', true);

                if (parentId) {
                    $.ajax({
                        url: '@Url.Action("GetChildCategories", "Admin")',
                        type: 'GET',
                        data: { parentId: parentId },
                        success: function(data) {
                            productTypeSelect.html('<option value="">請選擇商品類型</option>');

                            if (data && data.length > 0) {
                                $.each(data, function(i, item) {
                                    var option = $('<option></option>').val(item.id).text(item.name);
                                    if (selectedId && item.id == selectedId) {
                                        option.prop('selected', true);
                                    }
                                    productTypeSelect.append(option);
                                });
                                productTypeSelect.prop('disabled', false);
                            } else {
                                productTypeSelect.html('<option value="">此分類下沒有子分類</option>');
                            }
                        },
                        error: function() {
                            productTypeSelect.html('<option value="">載入失敗</option>');
                            alert('載入子分類失敗，請重試');
                        }
                    });
                } else {
                    productTypeSelect.html('<option value="">請先選擇大分類</option>');
                    productTypeSelect.prop('disabled', true);
                }
            }

            // 當父分類變更時，載入對應的子分類
            $('#ParentCategorySelect').change(function() {
                var parentId = $(this).val();
                loadChildCategories(parentId, null);
            });

            // 頁面載入時，如果有選擇的父分類，自動載入子分類
            var initialParentId = $('#ParentCategorySelect').val();
            if (initialParentId) {
                loadChildCategories(initialParentId, selectedProductTypeId);
            }
        });
    </script>
}