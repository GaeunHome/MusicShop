@model MusicShop.Models.Order
@{
    ViewData["Title"] = $"訂單 #{Model.Id}";
    ViewData["PageId"] = "admin-order-detail";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-bold d-flex justify-content-between">
                    <span>📦 訂單 #@Model.Id</span>
                    <a asp-action="Orders" class="btn btn-sm btn-outline-secondary">← 返回訂單列表</a>
                </div>
                <div class="card-body">

                    <dl class="row mb-4">
                        <dt class="col-sm-3">會員</dt>
                        <dd class="col-sm-9">@Model.User?.Email</dd>
                        <dt class="col-sm-3">下單時間</dt>
                        <dd class="col-sm-9">@Model.OrderDate.ToString("yyyy/MM/dd HH:mm")</dd>
                        <dt class="col-sm-3">總金額</dt>
                        <dd class="col-sm-9 fw-bold text-primary">NT$ @Model.TotalAmount</dd>
                    </dl>

                    <table class="table">
                        <thead class="table-light">
                            <tr>
                                <th>專輯</th>
                                <th>單價</th>
                                <th>數量</th>
                                <th>小計</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.Album?.Title</td>
                                    <td>NT$ @item.UnitPrice</td>
                                    <td>@item.Quantity</td>
                                    <td>NT$ @(item.UnitPrice * item.Quantity)</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <hr />

                    <form asp-action="UpdateOrderStatus" method="post" class="d-flex align-items-center gap-3">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <label class="fw-bold">更新狀態：</label>
                        <select name="status" class="form-select w-auto">
                            @foreach (MusicShop.Models.OrderStatus s in Enum.GetValues(typeof(MusicShop.Models.OrderStatus)))
                            {
                                var label = s switch
                                {
                                    MusicShop.Models.OrderStatus.Pending => "待處理",
                                    MusicShop.Models.OrderStatus.Paid => "已付款",
                                    MusicShop.Models.OrderStatus.Shipped => "已出貨",
                                    MusicShop.Models.OrderStatus.Completed => "已完成",
                                    MusicShop.Models.OrderStatus.Cancelled => "已取消",
                                    _ => s.ToString()
                                };

                                if (Model.Status == s)
                                {
                                    <option value="@((int)s)" selected>@label</option>
                                }
                                else
                                {
                                    <option value="@((int)s)">@label</option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-primary">更新</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>