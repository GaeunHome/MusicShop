@model IEnumerable<MusicShop.Models.Order>
@{
    ViewData["Title"] = "訂單管理";
    ViewData["PageId"] = "admin-orders";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>📦 訂單管理</h3>
        <a asp-action="Index" class="btn btn-outline-secondary">← 返回後台</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>訂單編號</th>
                    <th>會員</th>
                    <th>下單時間</th>
                    <th>總金額</th>
                    <th>狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>@order.User?.Email</td>
                        <td>@order.OrderDate.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>NT$ @order.TotalAmount</td>
                        <td>
                            @switch (order.Status)
                            {
                                case MusicShop.Models.OrderStatus.Pending:
                                    <span class="badge bg-warning text-dark">待處理</span>
                                    break;
                                case MusicShop.Models.OrderStatus.Paid:
                                    <span class="badge bg-info">已付款</span>
                                    break;
                                case MusicShop.Models.OrderStatus.Shipped:
                                    <span class="badge bg-primary">已出貨</span>
                                    break;
                                case MusicShop.Models.OrderStatus.Completed:
                                    <span class="badge bg-success">已完成</span>
                                    break;
                                case MusicShop.Models.OrderStatus.Cancelled:
                                    <span class="badge bg-danger">已取消</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a asp-action="OrderDetail" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary">查看</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>