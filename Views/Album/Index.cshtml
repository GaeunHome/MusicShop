@model IEnumerable<MusicShop.Models.Album>
@{
    ViewData["Title"] = "專輯列表";
    var categories = ViewBag.Categories as IEnumerable<MusicShop.Models.Category>;
}

<div class="container mt-4">

    <form method="get" asp-action="Index" class="row g-2 mb-4">
        <div class="col-md-5">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="🔍 搜尋專輯名稱或歌手..." />
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select">
                <option value="">所有分類</option>
                @foreach (var cat in categories ?? Enumerable.Empty<MusicShop.Models.Category>())
                {
                    <option value="@cat.Id"
                        selected="@(ViewBag.CategoryId != null && (int)ViewBag.CategoryId == cat.Id ? "selected" : null)">
                        @cat.Name
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">搜尋</button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">清除</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5">
            <h5>找不到相關專輯 😢</h5>
            <a asp-action="Index" class="btn btn-outline-primary mt-3">查看全部專輯</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var album in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(album.CoverImageUrl))
                        {
                            <img src="@album.CoverImageUrl" class="card-img-top"
                                 style="height:200px; object-fit:cover;" alt="@album.Title" />
                        }
                        else
                        {
                            <div class="bg-secondary d-flex align-items-center justify-content-center"
                                 style="height:200px;">
                                <span class="text-white fs-1">🎵</span>
                            </div>
                        }
                        <div class="card-body">
                            <h6 class="card-title mb-1">@album.Title</h6>
                            <p class="text-muted small mb-1">@album.Artist</p>
                            <span class="badge bg-secondary">@album.Category?.Name</span>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary">NT$ @album.Price</span>
                            <a asp-action="Detail" asp-route-id="@album.Id"
                               class="btn btn-sm btn-outline-primary">查看詳情</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>