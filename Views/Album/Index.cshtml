@model IEnumerable<MusicShop.Models.Album>
@{
    ViewData["Title"] = "商品列表";
    var artistCategories = ViewBag.ArtistCategories as IEnumerable<MusicShop.Models.ArtistCategory>;
    var childCategories = ViewBag.ChildCategories as IEnumerable<MusicShop.Models.ProductType>;

    // 取得目前的篩選資訊
    var currentArtistCategoryId = ViewBag.ArtistCategoryId as int?;
    var currentArtistId = ViewBag.ArtistId as int?;
    var currentProductTypeId = ViewBag.ProductTypeId as int?;
    var currentParentProductTypeId = ViewBag.ParentProductTypeId as int?;
    var currentSearch = ViewBag.Search as string;
    var currentSortBy = ViewBag.SortBy as string;
    var parentCategoryName = ViewBag.ParentCategoryName as string;
    var selectedArtist = ViewBag.SelectedArtist as MusicShop.Models.Artist;

    // 找出當前選擇的分類名稱
    var currentArtistCategoryName = currentArtistCategoryId.HasValue
        ? artistCategories?.FirstOrDefault(c => c.Id == currentArtistCategoryId.Value)?.Name
        : null;
    var currentProductTypeName = currentProductTypeId.HasValue
        ? childCategories?.FirstOrDefault(c => c.Id == currentProductTypeId.Value)?.Name
        : null;
}

<div class="container mt-4">

    <!-- 麵包屑導航 / 當前分類顯示 -->
    @if (currentArtistCategoryName != null || currentProductTypeName != null || parentCategoryName != null || !string.IsNullOrEmpty(currentSearch))
    {
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">所有商品</a></li>
                @if (currentArtistCategoryName != null)
                {
                    <li class="breadcrumb-item active" aria-current="page">K-ARTIST › @currentArtistCategoryName</li>
                }
                @if (parentCategoryName != null && currentProductTypeName == null)
                {
                    <li class="breadcrumb-item active" aria-current="page">@parentCategoryName</li>
                }
                @if (currentProductTypeName != null && currentProductTypeId.HasValue)
                {
                    var parent = childCategories?.FirstOrDefault(c => c.Id == currentProductTypeId.Value)?.Parent;
                    if (parent != null)
                    {
                        <li class="breadcrumb-item">@parent.Name</li>
                    }
                    <li class="breadcrumb-item active" aria-current="page">@currentProductTypeName</li>
                }
                @if (!string.IsNullOrEmpty(currentSearch))
                {
                    <li class="breadcrumb-item active" aria-current="page">搜尋: @currentSearch</li>
                }
            </ol>
        </nav>
    }

    <!-- 搜尋條件區域 -->
    <div class="search-filter-section mb-4">
        <form method="get" asp-action="Index" id="searchForm">
            <div class="row g-3 align-items-center">
                <!-- 搜尋框 -->
                <div class="col-lg-5 col-md-6">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text"
                               name="search"
                               value="@ViewBag.Search"
                               class="form-control search-input"
                               placeholder="搜尋商品名稱或歌手..." />
                    </div>
                </div>

                <!-- 藝人分類選擇器 -->
                <div class="col-lg-3 col-md-3">
                    <select name="artistCategoryId" class="form-select filter-select">
                        <option value="">所有藝人分類</option>
                        @foreach (var ac in artistCategories ?? Enumerable.Empty<MusicShop.Models.ArtistCategory>())
                        {
                            <option value="@ac.Id"
                                selected="@(ViewBag.ArtistCategoryId != null && (int)ViewBag.ArtistCategoryId == ac.Id ? "selected" : null)">
                                @ac.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- 商品類型選擇器 -->
                <div class="col-lg-3 col-md-3">
                    <select name="productTypeId" class="form-select filter-select">
                        <option value="">所有商品類型</option>
                        @if (childCategories != null)
                        {
                            var groupedByParent = childCategories.GroupBy(c => c.Parent);
                            foreach (var group in groupedByParent.OrderBy(g => g.Key?.DisplayOrder ?? 0))
                            {
                                if (group.Key != null)
                                {
                                    <optgroup label="@group.Key.Name">
                                        @foreach (var child in group.OrderBy(c => c.DisplayOrder))
                                        {
                                            <option value="@child.Id"
                                                selected="@(ViewBag.ProductTypeId != null && (int)ViewBag.ProductTypeId == child.Id ? "selected" : null)">
                                                @child.Name
                                            </option>
                                        }
                                    </optgroup>
                                }
                            }
                        }
                    </select>
                </div>

                <!-- 按鈕組 -->
                <div class="col-lg-1 col-md-12">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-search"></i> 搜尋
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill" title="清除篩選">
                            <i class="bi bi-arrow-clockwise"></i>
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @{
        // 按藝人分組商品（用於有商品時顯示）
        var albumsByArtist = Model.GroupBy(a => a.Artist).OrderBy(g => g.Key?.DisplayOrder ?? 999);
    }

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5 py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-inbox mb-3 opacity-50" viewBox="0 0 16 16">
                <path d="M4.98 4a.5.5 0 0 0-.39.188L1.54 8H6a.5.5 0 0 1 .5.5 1.5 1.5 0 1 0 3 0A.5.5 0 0 1 10 8h4.46l-3.05-3.812A.5.5 0 0 0 11.02 4H4.98zm9.954 5H10.45a2.5 2.5 0 0 1-4.9 0H1.066l.32 2.562a.5.5 0 0 0 .497.438h12.234a.5.5 0 0 0 .496-.438L14.933 9zM3.809 3.563A1.5 1.5 0 0 1 4.981 3h6.038a1.5 1.5 0 0 1 1.172.563l3.7 4.625a.5.5 0 0 1 .105.374l-.39 3.124A1.5 1.5 0 0 1 14.117 13H1.883a1.5 1.5 0 0 1-1.489-1.314l-.39-3.124a.5.5 0 0 1 .106-.374l3.7-4.625z"/>
            </svg>
            <h5 class="mb-3">找不到符合條件的商品</h5>
            <p class="text-muted mb-4">試試看調整搜尋條件或瀏覽其他分類</p>
            <a asp-action="Index" class="btn btn-primary">查看全部商品</a>
        </div>
    }
    else
    {
        <!-- 排序與顯示控制區域 -->
        <div class="toolbar-section mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <!-- 左側：排序按鈕組 -->
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <!-- 排序下拉選單 -->
                    <div class="dropdown">
                        <button class="btn btn-sort dropdown-toggle @(string.IsNullOrEmpty(currentSortBy) ? "active" : "")"
                                type="button"
                                id="sortDropdown"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            預設排序
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="sortDropdown">
                            <li><a class="dropdown-item @(string.IsNullOrEmpty(currentSortBy) ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "" })">
                                <i class="bi bi-arrow-down-up me-2"></i>預設排序
                            </a></li>
                            <li><a class="dropdown-item @(currentSortBy == "date-new-old" ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "date-new-old" })">
                                <i class="bi bi-calendar-event me-2"></i>最新上架
                            </a></li>
                            <li><a class="dropdown-item @(currentSortBy == "date-old-new" ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "date-old-new" })">
                                <i class="bi bi-calendar me-2"></i>最舊上架
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item @(currentSortBy == "weekly-hot" ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "weekly-hot" })">
                                <i class="bi bi-fire me-2"></i>本週熱賣
                            </a></li>
                        </ul>
                    </div>

                    <!-- 價格排序下拉選單 -->
                    <div class="dropdown">
                        <button class="btn btn-sort dropdown-toggle @(currentSortBy?.Contains("price") == true ? "active" : "")"
                                type="button"
                                id="priceDropdown"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            價格
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="priceDropdown">
                            <li><a class="dropdown-item @(currentSortBy == "price-low-high" ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "price-low-high" })">
                                <i class="bi bi-sort-numeric-down me-2"></i>價格由低到高
                            </a></li>
                            <li><a class="dropdown-item @(currentSortBy == "price-high-low" ? "active" : "")"
                                   href="@Url.Action("Index", new { search = currentSearch, artistCategoryId = currentArtistCategoryId, artistId = currentArtistId, productTypeId = currentProductTypeId, parentProductTypeId = currentParentProductTypeId, sortBy = "price-high-low" })">
                                <i class="bi bi-sort-numeric-down-alt me-2"></i>價格由高到低
                            </a></li>
                        </ul>
                    </div>
                </div>

                <!-- 右側：商品數量與視圖切換 -->
                <div class="d-flex align-items-center gap-3">
                    <!-- 商品類型快速篩選（移到右側） -->
                    <select name="productTypeId"
                            class="form-select filter-select-small"
                            onchange="window.location.href='@Url.Action("Index")?search=@currentSearch&artistCategoryId=@currentArtistCategoryId&artistId=@currentArtistId&productTypeId=' + this.value + '&sortBy=@currentSortBy'">
                        <option value="">所有商品類型</option>
                        @if (childCategories != null)
                        {
                            var groupedByParent = childCategories.GroupBy(c => c.Parent);
                            foreach (var group in groupedByParent.OrderBy(g => g.Key?.DisplayOrder ?? 0))
                            {
                                if (group.Key != null)
                                {
                                    <optgroup label="@group.Key.Name">
                                        @foreach (var child in group.OrderBy(c => c.DisplayOrder))
                                        {
                                            <option value="@child.Id"
                                                selected="@(ViewBag.ProductTypeId != null && (int)ViewBag.ProductTypeId == child.Id ? "selected" : null)">
                                                @child.Name
                                            </option>
                                        }
                                    </optgroup>
                                }
                            }
                        }
                    </select>

                    <!-- 商品數量 -->
                    <span class="text-muted product-count">共 @Model.Count() 件商品</span>

                    <!-- 視圖切換按鈕 -->
                    <div class="btn-group view-toggle" role="group" aria-label="視圖切換">
                        <button type="button" class="btn btn-sm btn-outline-secondary active" title="網格檢視">
                            <i class="bi bi-grid-3x3-gap"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" title="列表檢視">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 按藝人分組顯示商品 -->
        @foreach (var artistGroup in albumsByArtist)
        {
            <!-- 藝人標題 -->
            <div class="mb-4 mt-5">
                <h2 class="artist-page-title">| @(artistGroup.Key?.Name ?? "未設定藝人")</h2>
            </div>

            <!-- 該藝人的商品網格 -->
            <div class="row row-cols-2 row-cols-lg-4 g-4 mb-5">
                @foreach (var album in artistGroup)
            {
                <div class="col">
                    <div class="product-item">
                        <!-- 專輯封面圖片區塊 -->
                        <div class="product-image-wrapper">
                            <!-- 底層連結，點擊整個圖片區域跳轉 -->
                            <a asp-action="Detail" asp-route-id="@album.Id" class="product-image-link"></a>

                            @if (!string.IsNullOrEmpty(album.CoverImageUrl))
                            {
                                <img src="@album.CoverImageUrl" class="product-image" alt="@album.Title">
                            }
                            else
                            {
                                <!-- 預設圖片 -->
                                <div class="product-image d-flex align-items-center justify-content-center"
                                     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                    <span class="text-white" style="font-size: 60px;">♪</span>
                                </div>
                            }

                            <!-- 庫存狀態標籤 -->
                            @if (album.Stock <= 0)
                            {
                                <span class="position-absolute top-0 end-0 badge bg-danger m-2" style="z-index: 10;">已售完</span>
                            }
                            else if (album.Stock <= 5)
                            {
                                <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2" style="z-index: 10;">僅剩 @album.Stock 件</span>
                            }

                            <!-- 懸停時顯示的按鈕 -->
                            <div class="product-overlay">
                                <div class="overlay-buttons d-flex gap-2 mb-2">
                                    <!-- 查看商品按鈕 -->
                                    <a asp-action="Detail" asp-route-id="@album.Id" class="btn btn-white overlay-btn">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                        </svg>
                                    </a>

                                    <!-- 加入購物車按鈕 -->
                                    @if (album.Stock > 0)
                                    {
                                        @if (User.Identity!.IsAuthenticated)
                                        {
                                            <button type="button" class="btn btn-purple overlay-btn"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#addToCartModal"
                                                    data-album-id="@album.Id"
                                                    data-album-title="@album.Title"
                                                    data-album-artist="@(album.Artist?.Name ?? "未設定藝人")"
                                                    data-album-price="@album.Price"
                                                    data-album-stock="@album.Stock"
                                                    data-album-image="@album.CoverImageUrl">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                                </svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="Login" class="btn btn-purple overlay-btn">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                                </svg>
                                            </a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- 商品資訊（照片下方） -->
                        <div class="product-info mt-3">
                            <a asp-action="Detail" asp-route-id="@album.Id" class="text-decoration-none text-dark">
                                <h6 class="product-title mb-2">@album.Title</h6>
                            </a>
                            <p class="product-price mb-0">
                                NT$@album.Price.ToString("N0")
                            </p>
                        </div>
                    </div>
                </div>
            }
            </div>
        }
    }
</div>

<!-- 引用共用的加入購物車 Modal -->
<partial name="_AddToCartModal" />

@* 引用專輯列表頁樣式 *@
@section Styles {
    <link rel="stylesheet" href="~/css/pages/album-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/add-to-cart-modal.js" asp-append-version="true"></script>
}