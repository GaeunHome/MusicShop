@model MusicShop.Models.Album
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <div class="row">

        {{!-- 封面圖 --}}
        <div class="col-md-4 text-center">
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <img src="@Model.CoverImageUrl" class="img-fluid rounded shadow" alt="@Model.Title" />
            }
            else
            {
                <div class="bg-secondary rounded d-flex align-items-center justify-content-center"
                     style="height:300px;">
                    <span class="text-white" style="font-size:80px;">🎵</span>
                </div>
            }
        </div>

        {{!-- 專輯資訊 --}}
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">專輯列表</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>

            <h2 class="mb-1">@Model.Title</h2>
            <p class="text-muted fs-5">@Model.Artist</p>
            <span class="badge bg-secondary mb-3">@Model.Category?.Name</span>

            <p>@Model.Description</p>

            <div class="d-flex align-items-center gap-3 mt-4">
                <span class="fs-3 fw-bold text-primary">NT$ @Model.Price</span>
                <span class="text-muted small">庫存：@(Model.Stock > 0 ? $"{Model.Stock} 張" : "已售完")</span>
            </div>

            <div class="mt-4">
                @if (Model.Stock > 0)
                {
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <form asp-controller="Cart" asp-action="Add" method="post">
                            <input type="hidden" name="albumId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary btn-lg">
                                🛒 加入購物車
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                            🔐 登入後購買
                        </a>
                    }
                }
                else
                {
                    <button class="btn btn-secondary btn-lg" disabled>已售完</button>
                }
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">← 返回列表</a>
            </div>
        </div>
    </div>
</div>