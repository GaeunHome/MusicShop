@model IEnumerable<MusicShop.Models.CartItem>
@{
    ViewData["Title"] = "購物車";
    var total = Model.Sum(c => c.Album!.Price * c.Quantity);
}

<div class="container mt-4">
    <h3 class="mb-4">🛒 我的購物車</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5">
            <h5>購物車是空的 🎵</h5>
            <a asp-controller="Album" asp-action="Index" class="btn btn-primary mt-3">去逛逛專輯</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>專輯</th>
                        <th>歌手</th>
                        <th>單價</th>
                        <th>數量</th>
                        <th>小計</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fs-4">🎵</span>
                                    <span class="fw-bold">@item.Album!.Title</span>
                                </div>
                            </td>
                            <td class="text-muted">@(item.Album.Artist?.Name ?? "未設定藝人")</td>
                            <td>NT$ @item.Album.Price</td>
                            <td>
                                <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-1">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="number" name="quantity" value="@item.Quantity"
                                           min="1" max="99" class="form-control form-control-sm"
                                           style="width:70px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">更新</button>
                                </form>
                            </td>
                            <td class="fw-bold text-primary">NT$ @(item.Album.Price * item.Quantity)</td>
                            <td>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('確定要移除嗎？')">移除</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4" class="text-end fw-bold fs-5">總計：</td>
                        <td colspan="2" class="fw-bold fs-5 text-primary">NT$ @total</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <a asp-controller="Album" asp-action="Index" class="btn btn-outline-secondary">← 繼續購物</a>
            <a asp-action="Checkout" class="btn btn-primary btn-lg">前往結帳 →</a>
        </div>
    }
</div>