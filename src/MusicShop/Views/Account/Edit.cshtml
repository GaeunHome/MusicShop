@model MusicShop.ViewModels.Account.EditProfileViewModel
@{
    ViewData["Title"] = "更新個人資訊";
}

<div id="account-edit-page" class="container my-5">
    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">首頁</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Account" asp-action="Index">我的帳戶</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">更新個人資訊</li>
        </ol>
    </nav>

    <h1 class="page-title mb-4">更新個人資訊</h1>

    <div class="row">
        <!-- 左側選單（桌面版） -->
        <div class="col-lg-3 d-none d-lg-block">
            @await Html.PartialAsync("_AccountMenu")
        </div>

        <!-- 右側內容 -->
        <div class="col-lg-9 col-12">
            <!-- 手機版選單 -->
            <div class="mobile-menu d-lg-none mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        更新個人資訊
                    </button>
                    <ul class="dropdown-menu w-100">
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Index">我的帳戶</a>
                        </li>
                        <li>
                            <a class="dropdown-item active" asp-controller="Account" asp-action="Edit">更新個人資訊</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">更新密碼</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Order" asp-action="Index">訂單查詢</a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- 成功訊息 -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- 編輯表單 -->
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label">姓名</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label">電子郵件</label>
                                <input asp-for="Email" class="form-control" type="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label">手機號碼</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="0912345678" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Birthday" class="form-label">生日</label>
                                <input asp-for="Birthday" class="form-control" type="date" />
                                <span asp-validation-for="Birthday" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">性別</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="Gender" value="1" id="genderMale" checked="@(Model.Gender == MusicShop.Models.Gender.Male)" />
                                        <label class="form-check-label" for="genderMale">男性</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="Gender" value="2" id="genderFemale" checked="@(Model.Gender == MusicShop.Models.Gender.Female)" />
                                        <label class="form-check-label" for="genderFemale">女性</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Gender" class="text-danger d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">註冊日期</label>
                                <input type="text" class="form-control-plaintext" value="@Model.RegisteredAt.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary">儲存變更</button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">取消</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
