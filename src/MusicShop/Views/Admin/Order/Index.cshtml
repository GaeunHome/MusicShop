@model IEnumerable<MusicShop.Models.Order>
@{
    ViewData["Title"] = "訂單管理";
    ViewData["PageId"] = "admin-orders";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>📦 訂單管理</h3>
        <a asp-action="Index" class="btn btn-outline-secondary">← 返回後台</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>訂單編號</th>
                    <th>會員</th>
                    <th>下單時間</th>
                    <th>總金額</th>
                    <th>付款方式</th>
                    <th>訂單狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>@order.User?.Email</td>
                        <td>@order.OrderDate.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>NT$ @order.TotalAmount</td>
                        <td>
                            @{
                                var paymentBadgeClass = order.PaymentMethod == MusicShop.Models.PaymentMethod.CashOnDelivery
                                    ? "bg-warning text-dark" : "bg-info";
                            }
                            <span class="badge @paymentBadgeClass">
                                @MusicShop.Helpers.OrderHelper.GetPaymentMethodText(order.PaymentMethod)
                            </span>
                        </td>
                        <td>
                            <span class="badge @MusicShop.Helpers.OrderHelper.GetOrderStatusBadgeClass(order.Status)">
                                @MusicShop.Helpers.OrderHelper.GetOrderStatusText(order.Status)
                            </span>
                        </td>
                        <td>
                            <a asp-action="OrderDetail" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary">查看</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>