@model MusicShop.Models.Artist
@{
    ViewData["Title"] = "新增藝人";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">➕ 新增藝人</div>
                <div class="card-body">
                    <form asp-action="ArtistCreate" method="post">
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger"></div>
                        }

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">藝人名稱</label>
                            <input asp-for="Name" class="form-control" placeholder="例如：BTS、BLACKPINK" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ArtistCategoryId" class="form-label">藝人分類 <span class="text-danger">*</span></label>
                            <select asp-for="ArtistCategoryId" asp-items="ViewBag.ArtistCategories" class="form-select">
                                <option value="0">請選擇藝人分類</option>
                            </select>
                            <span asp-validation-for="ArtistCategoryId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">藝人簡介（選填）</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="例如：韓國男子團體，2013 年出道"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProfileImageUrl" class="form-label">形象圖片 URL（選填）</label>
                            <input asp-for="ProfileImageUrl" class="form-control" placeholder="https://example.com/artist.jpg" />
                            <small class="text-muted">請輸入完整的圖片網址</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">排序順序</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" value="0" />
                            <small class="text-muted">數字越小排序越前面</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Artists" class="btn btn-outline-secondary">← 取消</a>
                            <button type="submit" class="btn btn-primary">新增藝人</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
