@model MusicShop.Data.Entities.ProductType
@{
    ViewData["Title"] = "新增商品類型";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white fw-bold">➕ 新增商品類型</div>
                <div class="card-body">
                    <form asp-action="ProductTypeCreate" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="ParentId" class="form-label">父分類（選填）</label>
                            <select asp-for="ParentId" asp-items="ViewBag.ParentCategories" class="form-select">
                                <option value="">無（建立為頂層分類）</option>
                            </select>
                            <small class="form-text text-muted">
                                選擇父分類可建立子分類。留空則建立頂層分類（如 K-ALBUM、K-MAGAZINE、K-MERCH、K-EVENT）
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label required">類型名稱</label>
                            <input asp-for="Name" class="form-control" placeholder="例如：手燈、VOGUE、ALBUM" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">描述（選填）</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="例如：演唱會應援手燈"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">排序順序</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" value="0" />
                            <small class="text-muted">數字越小排序越前面</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Categories" class="btn btn-outline-secondary">← 取消</a>
                            <button type="submit" class="btn btn-success">新增類型</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
