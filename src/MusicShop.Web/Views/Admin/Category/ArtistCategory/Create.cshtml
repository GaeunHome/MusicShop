@model MusicShop.Data.Entities.ArtistCategory
@{
    ViewData["Title"] = "新增藝人分類";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">➕ 新增藝人分類</div>
                <div class="card-body">
                    <form asp-action="ArtistCategoryCreate" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">分類名稱</label>
                            <input asp-for="Name" class="form-control" placeholder="例如：男子團體" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">描述（選填）</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="例如：男子偶像團體"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">排序順序</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" value="0" />
                            <small class="text-muted">數字越小排序越前面</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Categories" class="btn btn-outline-secondary">← 取消</a>
                            <button type="submit" class="btn btn-primary">新增分類</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
