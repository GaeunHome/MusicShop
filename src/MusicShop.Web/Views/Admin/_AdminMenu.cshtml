@* 後台管理側邊選單 *@
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="bi bi-speedometer2"></i> 後台管理</h5>
    </div>
    <div class="list-group list-group-flush">
        <a asp-controller="Admin" asp-action="Index"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-house-door"></i> 管理首頁
        </a>
        <a asp-controller="Admin" asp-action="Albums"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Albums" || ViewContext.RouteData.Values["Action"]?.ToString() == "AlbumCreate" || ViewContext.RouteData.Values["Action"]?.ToString() == "AlbumEdit" ? "active" : "")">
            <i class="bi bi-music-note-list"></i> 專輯管理
        </a>
        <a asp-controller="Admin" asp-action="Artists"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Artists" || ViewContext.RouteData.Values["Action"]?.ToString() == "ArtistCreate" || ViewContext.RouteData.Values["Action"]?.ToString() == "ArtistEdit" ? "active" : "")">
            <i class="bi bi-mic"></i> 藝人管理
        </a>
        <a asp-controller="Admin" asp-action="Categories"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Categories" || ViewContext.RouteData.Values["Action"]?.ToString() == "CategoryCreate" || ViewContext.RouteData.Values["Action"]?.ToString() == "CategoryEdit" ? "active" : "")">
            <i class="bi bi-tags"></i> 分類管理
        </a>
        <a asp-controller="Admin" asp-action="Orders"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Orders" || ViewContext.RouteData.Values["Action"]?.ToString() == "OrderDetail" ? "active" : "")">
            <i class="bi bi-box-seam"></i> 訂單管理
        </a>
        <a asp-controller="Admin" asp-action="Users"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")">
            <i class="bi bi-person-badge"></i> 使用者管理
        </a>
        <a asp-controller="Admin" asp-action="Banners"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() is "Banners" or "BannerCreate" or "BannerEdit" ? "active" : "")">
            <i class="bi bi-image"></i> 幻燈片管理
        </a>
    </div>
    <div class="card-footer">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">
            <i class="bi bi-arrow-left"></i> 返回前台
        </a>
    </div>
</div>
