@model List<AlbumCardViewModel>
@{
    ViewData["Title"] = "首頁 - MusicShop";
    ViewData["PageId"] = "home-index";
    var wishlistIds = ViewBag.WishlistIds as HashSet<int> ?? new HashSet<int>();
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

@{
    var banners = ViewBag.Banners as IEnumerable<BannerDisplayViewModel> ?? [];
    var bannerList = banners.ToList();
}

@if (bannerList.Any())
{
    @section Banner {
    <div id="homeCarousel" class="carousel slide" data-bs-ride="carousel">
        <!-- 輪播指示點 -->
        <div class="carousel-indicators">
            @for (int i = 0; i < bannerList.Count; i++)
            {
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        aria-label="Slide @(i + 1)"
                        @(i == 0 ? "aria-current=true" : "")></button>
            }
        </div>

        <!-- 輪播內容 -->
        <div class="carousel-inner">
            @for (int i = 0; i < bannerList.Count; i++)
            {
                var banner = bannerList[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    @if (banner.HasLinkedAlbum)
                    {
                        <a asp-controller="Album" asp-action="Detail" asp-route-id="@banner.AlbumId">
                            @* 第一張幻燈片為首屏內容，不加延遲載入；其餘使用 lazy loading *@
                            <img src="@banner.ImageUrl" class="d-block w-100" alt="幻燈片 @(i + 1)"
                                 @(i > 0 ? "loading=lazy" : "")>
                        </a>
                    }
                    else
                    {
                        <img src="@banner.ImageUrl" class="d-block w-100" alt="幻燈片 @(i + 1)"
                             @(i > 0 ? "loading=lazy" : "")>
                    }
                </div>
            }
        </div>

        @if (bannerList.Count > 1)
        {
            <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">上一張</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">下一張</span>
            </button>
        }
    </div>
    }
}

<!-- 最新上架專輯區塊 -->
<div id="latest-albums" class="mb-5">
    <div class="section-heading text-center mb-4">
        <a asp-controller="Album" asp-action="Index" class="section-heading-anchor text-decoration-none">
            <h2 class="section-title">新品上市</h2>
        </a>
    </div>

    @if (User.Identity!.IsAuthenticated)
    {
        <form id="wishlistForm" style="display:none;">@Html.AntiForgeryToken()</form>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-2 row-cols-lg-4 g-4">
            @foreach (var album in Model)
            {
                @await Html.PartialAsync("_AlbumCard", album)
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-info-circle fs-1"></i>
            <p class="mb-0 mt-3 fs-5">目前沒有最新商品</p>
        </div>
    }

    <!-- 查看更多連結 -->
    <div class="text-center mt-5">
        <a asp-controller="Album" asp-action="Index" class="view-all-link">查看所有專輯 →</a>
    </div>
</div>

<!-- 引用共用的加入購物車 Modal -->
<partial name="_AddToCartModal" />

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/features/home/carousel.js" asp-append-version="true"></script>
    <script src="~/js/features/cart/add-modal.js" asp-append-version="true"></script>
    <script src="~/js/features/wishlist/wishlist.js" asp-append-version="true"></script>
}
