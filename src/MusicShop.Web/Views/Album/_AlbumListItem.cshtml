@model MusicShop.Data.Entities.Album
@{
    var wishlistIds = ViewData["WishlistIds"] as HashSet<int> ?? new HashSet<int>();
    bool isInWishlist = wishlistIds.Contains(Model.Id);
}

<div class="product-list-item">
    <div class="position-relative">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="product-list-image" alt="@Model.Title">
        }
        else
        {
            <div class="product-list-image-placeholder">
                <span class="text-white" style="font-size: 40px;">♪</span>
            </div>
        }

        @if (Model.Stock <= 0)
        {
            <span class="position-absolute top-0 start-0 badge bg-danger m-1" style="font-size: 0.7rem;">已售完</span>
        }
        else if (Model.Stock <= 5)
        {
            <span class="position-absolute top-0 start-0 badge bg-warning text-dark m-1" style="font-size: 0.7rem;">僅剩 @Model.Stock 件</span>
        }
    </div>

    <div class="product-list-info">
        <a asp-action="Detail" asp-route-id="@Model.Id" class="product-list-title">@Model.Title</a>
        <div class="product-list-artist">@(Model.Artist?.Name ?? "未設定藝人")</div>
        <div class="product-list-price mt-2">NT$@Model.Price.ToString("N0")</div>
    </div>

    <div class="product-list-actions">
        @if (Model.Stock > 0)
        {
            @if (User.Identity!.IsAuthenticated)
            {
                <button type="button" class="btn btn-primary"
                        data-bs-toggle="modal" data-bs-target="#addToCartModal"
                        data-album-id="@Model.Id"
                        data-album-title="@Model.Title"
                        data-album-artist="@(Model.Artist?.Name ?? "未設定藝人")"
                        data-album-price="@Model.Price"
                        data-album-stock="@Model.Stock"
                        data-album-image="@Model.CoverImageUrl">
                    加入購物車
                </button>
            }
            else
            {
                <button type="button" class="btn btn-primary" data-require-auth>加入購物車</button>
            }
        }
        else
        {
            <button type="button" class="btn btn-secondary" disabled>商品已售完</button>
        }

        <!-- 收藏按鈕 -->
        @if (User.Identity!.IsAuthenticated)
        {
            <button type="button"
                    class="btn-wishlist wishlist-toggle @(isInWishlist ? "wishlisted" : "")"
                    data-album-id="@Model.Id"
                    title="@(isInWishlist ? "取消收藏" : "加入收藏")">
                <i class="bi @(isInWishlist ? "bi-heart-fill text-danger" : "bi-heart")"></i>
            </button>
        }
        else
        {
            <button type="button" class="btn-wishlist" data-require-auth title="登入後加入收藏">
                <i class="bi bi-heart"></i>
            </button>
        }
    </div>
</div>
