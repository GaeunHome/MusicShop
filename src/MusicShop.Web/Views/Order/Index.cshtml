@model List<OrderListItemViewModel>
@{
    ViewData["Title"] = "訂單查詢";
    ViewData["PageId"] = "order-index";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div id="order-list-page" class="container my-5">
    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">首頁</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Account" asp-action="Index">我的帳戶</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">訂單查詢</li>
        </ol>
    </nav>

    <h1 class="page-title mb-4">訂單查詢</h1>

    <div class="row">
        <!-- 左側選單（桌面版） -->
        <div class="col-lg-3 d-none d-lg-block">
            @await Html.PartialAsync("~/Views/Account/_AccountMenu.cshtml")
        </div>

        <!-- 右側內容 -->
        <div class="col-lg-9 col-12">
            <!-- 手機版選單 -->
            <div class="mobile-menu d-lg-none mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        訂單查詢
                    </button>
                    <ul class="dropdown-menu w-100">
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Index">我的帳戶</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Edit">更新個人資訊</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">更新密碼</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="TwoFactorAuthentication">兩步驟驗證</a>
                        </li>
                        <li>
                            <a class="dropdown-item active" asp-controller="Order" asp-action="Index">訂單查詢</a>
                        </li>
                    </ul>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <!-- 訂單列表 -->
                <div class="orders-list">
                    @foreach (var order in Model)
                    {
                        <div class="order-card card mb-3">
                            <div class="card-header bg-white">
                                <div class="row align-items-center">
                                    <div class="col-md-4">
                                        <strong>訂單編號：</strong>
                                        <a asp-action="Detail" asp-route-id="@order.Id" class="text-primary">
                                            #@order.Id
                                        </a>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <span class="text-muted">訂單日期：@order.FormattedOrderDate</span>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <span class="badge @order.StatusBadgeClass">@order.StatusText</span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <!-- 訂單商品 -->
                                    <div class="col-md-6">
                                        <h6 class="mb-2">訂單商品：</h6>
                                        @foreach (var item in order.Items)
                                        {
                                            <div class="order-item mb-2">
                                                <strong>@item.AlbumTitle</strong>
                                                <span class="text-muted ms-2">x @item.Quantity</span>
                                                <span class="text-primary ms-2">NT$@item.FormattedUnitPrice</span>
                                            </div>
                                        }
                                        @if (order.HasMoreItems)
                                        {
                                            <small class="text-muted">還有 @order.ExtraItemCount 項商品...</small>
                                        }
                                    </div>

                                    <!-- 總金額和操作 -->
                                    <div class="col-md-6 text-end">
                                        <div class="mb-3">
                                            @if (order.HasDiscount)
                                            {
                                                <div class="text-muted text-decoration-line-through small">
                                                    商品總計：NT$@order.FormattedTotalAmount
                                                </div>
                                                <div class="text-danger small">
                                                    優惠折扣：-NT$@order.FormattedDiscountAmount
                                                </div>
                                            }
                                            <h5 class="mb-0">
                                                <strong class="text-primary">實付金額：NT$@order.FormattedFinalAmount</strong>
                                            </h5>
                                        </div>
                                        <div class="d-flex gap-2 justify-content-end">
                                            <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-primary">
                                                查看詳情
                                            </a>
                                            @if (order.CanRetryPayment)
                                            {
                                                <a asp-controller="Payment" asp-action="Checkout" asp-route-orderId="@order.Id"
                                                   class="btn btn-primary">
                                                    <i class="bi bi-credit-card me-1"></i>前往付款
                                                </a>
                                            }
                                            @if (order.CanCancel)
                                            {
                                                <form asp-action="Cancel" asp-route-id="@order.Id" method="post" class="d-inline" id="cancelOrderForm_@order.Id">
                                                    <button type="button" class="btn btn-outline-danger"
                                                            data-order-cancel
                                                            data-order-id="@order.Id">取消訂單</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-muted mt-3">
                    共 @Model.Count 筆訂單
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    目前沒有訂單記錄
                </div>
                <div class="text-center mt-4">
                    <a asp-controller="Album" asp-action="Index" class="btn btn-primary">
                        前往購物
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}
