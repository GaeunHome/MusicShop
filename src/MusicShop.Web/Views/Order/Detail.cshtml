@model OrderDetailViewModel
@{
    ViewData["Title"] = $"訂單詳情 - #{Model.Id}";
    ViewData["PageId"] = "order-detail";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div id="order-detail-page" class="container my-5">
    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">首頁</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Account" asp-action="Index">我的帳戶</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Order" asp-action="Index">訂單查詢</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">訂單詳情 #@Model.Id</li>
        </ol>
    </nav>

    <h1 class="page-title mb-4">訂單詳情</h1>

    <!-- 訂單狀態時間軸 -->
    @await Html.PartialAsync("_OrderTimeline", Model.Status)

    <div class="row">
        <!-- 訂單資訊 -->
        <div class="col-lg-8 mb-4">
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0">訂單資訊</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>訂單編號：</strong>
                        </div>
                        <div class="col-8">
                            #@Model.Id
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>訂單日期：</strong>
                        </div>
                        <div class="col-8">
                            @Model.FormattedOrderDate
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>訂單狀態：</strong>
                        </div>
                        <div class="col-8">
                            <span class="badge @Model.StatusBadgeClass">@Model.StatusText</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>付款方式：</strong>
                        </div>
                        <div class="col-8">
                            @Model.PaymentMethodText（@Model.PaymentStatusText）
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>配送方式：</strong>
                        </div>
                        <div class="col-8">
                            @Model.DeliveryMethodText
                        </div>
                    </div>
                </div>
            </div>

            <!-- 收件資訊 -->
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0">收件資訊</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>收件人：</strong>
                        </div>
                        <div class="col-8">
                            @Model.ReceiverName
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>聯絡電話：</strong>
                        </div>
                        <div class="col-8">
                            @Model.ReceiverPhone
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4">
                            <strong>收件地址：</strong>
                        </div>
                        <div class="col-8">
                            @Model.FullAddress
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.OrderNote))
                    {
                        <div class="row mb-2">
                            <div class="col-4">
                                <strong>訂單備註：</strong>
                            </div>
                            <div class="col-8 text-muted">
                                @Model.OrderNote
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- 訂單商品 -->
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">訂單商品</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>商品名稱</th>
                                    <th class="text-center">單價</th>
                                    <th class="text-center">數量</th>
                                    <th class="text-end">小計</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Album" asp-action="Detail" asp-route-id="@item.AlbumId" class="text-decoration-none">
                                                @item.AlbumTitle
                                            </a>
                                        </td>
                                        <td class="text-center">NT$@item.FormattedUnitPrice</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end text-primary">
                                            <strong>NT$@item.FormattedSubTotal</strong>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 訂單摘要 -->
        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0">訂單摘要</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>商品數量：</span>
                        <span>@Model.TotalQuantity 件</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>商品小計：</span>
                        <span>NT$@Model.FormattedTotalAmount</span>
                    </div>
                    @if (Model.HasDiscount)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>優惠券折扣：</span>
                            <span class="text-danger">-NT$@Model.FormattedDiscountAmount</span>
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong class="fs-5">實付金額：</strong>
                        <strong class="fs-5 text-primary">NT$@Model.FormattedFinalAmount</strong>
                    </div>
                </div>
            </div>

            <!-- 操作按鈕 -->
            <div class="d-grid gap-2">
                @if (Model.CanCancel)
                {
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" id="cancelOrderFormDetail">
                        <button type="button" class="btn btn-danger w-100" data-order-cancel-detail>取消訂單</button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-outline-secondary">返回訂單列表</a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}
