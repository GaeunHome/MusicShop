@model MusicShop.Data.Entities.Order
@{
    ViewData["Title"] = "訂單完成";
}

<!-- TempData 訊息（隱藏，用於 JavaScript 讀取） -->
@if (TempData["Success"] != null)
{
    <div data-tempdata-success="@TempData["Success"]" style="display:none;"></div>
}
@if (TempData["Error"] != null)
{
    <div data-tempdata-error="@TempData["Error"]" style="display:none;"></div>
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <div class="display-1">🎉</div>
        <h2 class="mt-3">訂單成立成功！</h2>
        <p class="text-muted">感謝您的購買，訂單編號：<strong>#@Model.Id</strong></p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">訂單明細</div>
                <div class="card-body">
                    <table class="table">
                        <thead class="table-light">
                            <tr>
                                <th>專輯</th>
                                <th>單價</th>
                                <th>數量</th>
                                <th>小計</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.Album?.Title</td>
                                    <td>NT$ @item.UnitPrice.ToString("N0")</td>
                                    <td>@item.Quantity</td>
                                    <td class="fw-bold">NT$ @((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">總計：</td>
                                <td class="fw-bold text-primary">NT$ @Model.TotalAmount.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="card-footer text-muted small">
                    訂單時間：@Model.OrderDate.ToString("yyyy/MM/dd HH:mm")　
                    狀態：<span class="badge bg-warning text-dark">待處理</span>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-controller="Album" asp-action="Index" class="btn btn-primary">繼續購物</a>
            </div>
        </div>
    </div>
</div>