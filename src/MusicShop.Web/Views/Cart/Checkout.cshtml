@model MusicShop.Service.ViewModels.Cart.CheckoutViewModel
@{
    ViewData["Title"] = "確認結帳";
    ViewData["PageId"] = "cart-checkout";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div class="container my-5">
    <!-- 頁面標題 -->
    <div class="page-header mb-4">
        <h2 class="checkout-title">
            <i class="bi bi-credit-card-fill me-2"></i>確認結帳
        </h2>
        <p class="text-muted">請填寫完整的收件資訊以完成訂單</p>
    </div>

    <form asp-action="PlaceOrder" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()

        <!-- 驗證摘要（顯示所有驗證錯誤）-->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>請修正以下錯誤</h5>
                <hr>
                <ul class="mb-0">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <!-- 左側：表單內容 -->
            <div class="col-lg-8 mb-4">

                <!-- ==================== 收件人資訊 ==================== -->
                <div class="card checkout-section mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-person-fill me-2"></i>收件人資訊</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ReceiverName" class="form-label required">收件人姓名</label>
                                <input asp-for="ReceiverName" class="form-control" placeholder="請輸入收件人姓名" />
                                <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ReceiverPhone" class="form-label required">收件人電話</label>
                                <input asp-for="ReceiverPhone" class="form-control" placeholder="例：0912345678" />
                                <span asp-validation-for="ReceiverPhone" class="text-danger small"></span>
                                <small class="form-text text-muted">手機：09XXXXXXXX 或 市話：XX-XXXXXXXX</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ==================== 配送方式 ==================== -->
                <div class="card checkout-section mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-truck me-2"></i>配送方式</h5>
                    </div>
                    <div class="card-body">
                        <div class="delivery-options">
                            <div class="form-check delivery-option">
                                <input class="form-check-input" type="radio" asp-for="DeliveryMethod"
                                       value="@((int)MusicShop.Data.Entities.DeliveryMethod.HomeDelivery)"
                                       id="delivery-home" checked />
                                <label class="form-check-label" for="delivery-home">
                                    <div class="option-content">
                                        <i class="bi bi-house-door-fill fs-4 text-primary me-2"></i>
                                        <div>
                                            <strong>宅配到府</strong>
                                            <small class="d-block text-muted">配送至指定地址</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="form-check delivery-option">
                                <input class="form-check-input" type="radio" asp-for="DeliveryMethod"
                                       value="@((int)MusicShop.Data.Entities.DeliveryMethod.SevenEleven)"
                                       id="delivery-711" />
                                <label class="form-check-label" for="delivery-711">
                                    <div class="option-content">
                                        <i class="bi bi-shop fs-4 text-success me-2"></i>
                                        <div>
                                            <strong>7-11 超商取貨</strong>
                                            <small class="d-block text-muted">送至指定 7-11 門市</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="form-check delivery-option">
                                <input class="form-check-input" type="radio" asp-for="DeliveryMethod"
                                       value="@((int)MusicShop.Data.Entities.DeliveryMethod.FamilyMart)"
                                       id="delivery-family" />
                                <label class="form-check-label" for="delivery-family">
                                    <div class="option-content">
                                        <i class="bi bi-shop fs-4 text-info me-2"></i>
                                        <div>
                                            <strong>全家超商取貨</strong>
                                            <small class="d-block text-muted">送至指定全家門市</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="DeliveryMethod" class="text-danger small"></span>

                        <!-- 宅配地址資訊（條件顯示）-->
                        <div id="address-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3"><i class="bi bi-geo-alt-fill me-2"></i>收件地址</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="City" class="form-label required">縣市</label>
                                    <select name="City" class="form-select" id="City" data-val="false">
                                        <option value="">請選擇縣市</option>
                                        @foreach (var city in (ViewBag.Cities as List<string>) ?? new List<string>())
                                        {
                                            <option value="@city">@city</option>
                                        }
                                    </select>
                                    <span class="text-danger small" id="City-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label for="District" class="form-label required">鄉鎮市區</label>
                                    <select name="District" class="form-select" id="District" disabled data-val="false">
                                        <option value="">請選擇鄉鎮市區</option>
                                    </select>
                                    <span class="text-danger small" id="District-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label for="PostalCode" class="form-label required">郵遞區號</label>
                                    <input name="PostalCode" class="form-control" id="PostalCode" readonly placeholder="自動帶入" data-val="false" />
                                    <span class="text-danger small" id="PostalCode-error"></span>
                                </div>
                                <div class="col-12">
                                    <label for="Address" class="form-label required">詳細地址</label>
                                    <input name="Address" class="form-control" id="Address" placeholder="請輸入詳細地址（路、街、巷、弄、號、樓）" data-val="false" />
                                    <span class="text-danger small" id="Address-error"></span>
                                </div>
                            </div>
                        </div>

                        <!-- 7-11 門市資訊（條件顯示）-->
                        <div id="seven-eleven-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3"><i class="bi bi-shop me-2"></i>7-11 門市資訊</h6>

                            <!-- 門市選擇按鈕 -->
                            <div class="mb-3">
                                <button type="button" class="btn btn-outline-primary" id="select-seven-eleven-btn">
                                    <i class="bi bi-search me-2"></i>選擇 7-11 門市
                                </button>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="SevenElevenStoreCode" class="form-label required">門市代號</label>
                                    <input name="SevenElevenStoreCode" class="form-control" id="SevenElevenStoreCode" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="SevenElevenStoreCode-error"></span>
                                </div>
                                <div class="col-md-8">
                                    <label for="SevenElevenStoreName" class="form-label required">門市名稱</label>
                                    <input name="SevenElevenStoreName" class="form-control" id="SevenElevenStoreName" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="SevenElevenStoreName-error"></span>
                                </div>
                                <div class="col-12">
                                    <label for="SevenElevenStoreAddress" class="form-label required">門市地址</label>
                                    <input name="SevenElevenStoreAddress" class="form-control" id="SevenElevenStoreAddress" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="SevenElevenStoreAddress-error"></span>
                                </div>
                            </div>
                        </div>

                        <!-- 全家門市資訊（條件顯示）-->
                        <div id="family-mart-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3"><i class="bi bi-shop me-2"></i>全家門市資訊</h6>

                            <!-- 門市選擇按鈕 -->
                            <div class="mb-3">
                                <button type="button" class="btn btn-outline-primary" id="select-family-mart-btn">
                                    <i class="bi bi-search me-2"></i>選擇全家門市
                                </button>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="FamilyMartStoreCode" class="form-label required">門市代號</label>
                                    <input name="FamilyMartStoreCode" class="form-control" id="FamilyMartStoreCode" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="FamilyMartStoreCode-error"></span>
                                </div>
                                <div class="col-md-8">
                                    <label for="FamilyMartStoreName" class="form-label required">門市名稱</label>
                                    <input name="FamilyMartStoreName" class="form-control" id="FamilyMartStoreName" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="FamilyMartStoreName-error"></span>
                                </div>
                                <div class="col-12">
                                    <label for="FamilyMartStoreAddress" class="form-label required">門市地址</label>
                                    <input name="FamilyMartStoreAddress" class="form-control" id="FamilyMartStoreAddress" readonly placeholder="選擇後自動帶入" data-val="false" />
                                    <span class="text-danger small" id="FamilyMartStoreAddress-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ==================== 付款方式 ==================== -->
                <div class="card checkout-section mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-wallet2 me-2"></i>付款方式</h5>
                    </div>
                    <div class="card-body">
                        <div class="payment-options">
                            <div class="form-check payment-option">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod"
                                       value="@((int)MusicShop.Data.Entities.PaymentMethod.CashOnDelivery)"
                                       id="payment-cod" checked />
                                <label class="form-check-label" for="payment-cod">
                                    <div class="option-content">
                                        <i class="bi bi-cash-coin fs-4 text-warning me-2"></i>
                                        <div>
                                            <strong>貨到付款</strong>
                                            <small class="d-block text-muted">收到商品時付款</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="form-check payment-option">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod"
                                       value="@((int)MusicShop.Data.Entities.PaymentMethod.CreditCard)"
                                       id="payment-card" />
                                <label class="form-check-label" for="payment-card">
                                    <div class="option-content">
                                        <i class="bi bi-credit-card-2-front fs-4 text-primary me-2"></i>
                                        <div>
                                            <strong>信用卡線上刷卡</strong>
                                            <small class="d-block text-muted">安全快速的線上付款</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="PaymentMethod" class="text-danger small"></span>

                        <!-- 信用卡資訊（條件顯示）-->
                        <div id="credit-card-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3">信用卡資訊</h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label for="CardNumber" class="form-label required">信用卡號</label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-credit-card"></i>
                                        </span>
                                        <input type="text" class="form-control" id="CardNumber"
                                               placeholder="1234 5678 9012 3456" maxlength="19" />
                                    </div>
                                    <small class="form-text text-muted">請輸入 16 位數卡號</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="CardHolderName" class="form-label required">持卡人姓名</label>
                                    <input type="text" class="form-control" id="CardHolderName"
                                           placeholder="如卡片上顯示的英文姓名" />
                                </div>
                                <div class="col-md-3">
                                    <label for="CardExpiry" class="form-label required">有效期限</label>
                                    <input type="text" class="form-control" id="CardExpiry"
                                           placeholder="MM/YY" maxlength="5" />
                                    <small class="form-text text-muted">月/年</small>
                                </div>
                                <div class="col-md-3">
                                    <label for="CardCVV" class="form-label required">安全碼 (CVV)</label>
                                    <input type="text" class="form-control" id="CardCVV"
                                           placeholder="123" maxlength="3" />
                                    <small class="form-text text-muted">卡片背面 3 碼</small>
                                </div>
                            </div>
                            <div class="alert alert-warning mt-3 mb-0">
                                <i class="bi bi-shield-lock me-2"></i>
                                <small>
                                    此為模擬金流介面。實際應用會透過第三方金流服務（如綠界、藍新）處理付款，
                                    信用卡資訊不會儲存在本系統資料庫中。
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ==================== 發票資訊 ==================== -->
                <div class="card checkout-section mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>發票資訊</h5>
                    </div>
                    <div class="card-body">
                        <div class="invoice-options">
                            <div class="form-check invoice-option">
                                <input class="form-check-input" type="radio" asp-for="InvoiceType"
                                       value="@((int)MusicShop.Data.Entities.InvoiceType.Duplicate)"
                                       id="invoice-duplicate" checked />
                                <label class="form-check-label" for="invoice-duplicate">
                                    <div class="option-content">
                                        <i class="bi bi-file-text fs-4 text-secondary me-2"></i>
                                        <div>
                                            <strong>二聯式發票（個人）</strong>
                                            <small class="d-block text-muted">一般個人使用</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="form-check invoice-option">
                                <input class="form-check-input" type="radio" asp-for="InvoiceType"
                                       value="@((int)MusicShop.Data.Entities.InvoiceType.Triplicate)"
                                       id="invoice-triplicate" />
                                <label class="form-check-label" for="invoice-triplicate">
                                    <div class="option-content">
                                        <i class="bi bi-building fs-4 text-primary me-2"></i>
                                        <div>
                                            <strong>三聯式發票（公司）</strong>
                                            <small class="d-block text-muted">公司報帳使用</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="form-check invoice-option">
                                <input class="form-check-input" type="radio" asp-for="InvoiceType"
                                       value="@((int)MusicShop.Data.Entities.InvoiceType.EInvoice)"
                                       id="invoice-einvoice" />
                                <label class="form-check-label" for="invoice-einvoice">
                                    <div class="option-content">
                                        <i class="bi bi-phone fs-4 text-success me-2"></i>
                                        <div>
                                            <strong>電子發票</strong>
                                            <small class="d-block text-muted">儲存於載具</small>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="InvoiceType" class="text-danger small"></span>

                        <!-- 三聯式發票欄位（條件顯示）-->
                        <div id="triplicate-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3">公司發票資訊</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="CompanyTaxId" class="form-label required">統一編號</label>
                                    <input name="CompanyTaxId" id="CompanyTaxId" class="form-control" placeholder="8 位數字" maxlength="8" data-val="false" />
                                    <span class="text-danger small" id="CompanyTaxId-error"></span>
                                </div>
                                <div class="col-md-8">
                                    <label for="CompanyName" class="form-label required">公司抬頭</label>
                                    <input name="CompanyName" id="CompanyName" class="form-control" placeholder="公司名稱" data-val="false" />
                                    <span class="text-danger small" id="CompanyName-error"></span>
                                </div>
                            </div>
                        </div>

                        <!-- 電子發票欄位（條件顯示）-->
                        <div id="einvoice-fields" class="mt-3 p-3 bg-light rounded" style="display: none;">
                            <h6 class="mb-3">電子發票資訊</h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label for="InvoiceCarrier" class="form-label required">載具號碼</label>
                                    <input name="InvoiceCarrier" id="InvoiceCarrier" class="form-control" placeholder="例：/ABCD123" data-val="false" />
                                    <span class="text-danger small" id="InvoiceCarrier-error"></span>
                                    <small class="form-text text-muted">手機條碼、自然人憑證條碼或會員載具</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ==================== 訂單備註 ==================== -->
                <div class="card checkout-section mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-chat-left-text me-2"></i>訂單備註（選填）</h5>
                    </div>
                    <div class="card-body">
                        <textarea asp-for="OrderNote" class="form-control" rows="3"
                                  placeholder="如有特殊需求請在此說明（例：配送時段偏好）"></textarea>
                        <span asp-validation-for="OrderNote" class="text-danger small"></span>
                        <small class="form-text text-muted">最多 1000 字元</small>
                    </div>
                </div>

            </div>

            <!-- 右側：訂單摘要 -->
            <div class="col-lg-4">
                <div class="card checkout-summary sticky-top">
                    <div class="card-header">
                        <h5 class="mb-0">訂單摘要</h5>
                    </div>
                    <div class="card-body">
                        <!-- 商品列表 -->
                        <div class="order-items mb-3">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="order-item">
                                    <div class="d-flex align-items-start mb-2">
                                        <div class="item-image me-3">
                                            @if (!string.IsNullOrEmpty(item.Album?.CoverImageUrl))
                                            {
                                                <img src="@item.Album.CoverImageUrl" alt="@item.Album.Title" class="img-thumbnail">
                                            }
                                            else
                                            {
                                                <div class="img-thumbnail placeholder-image">
                                                    <i class="bi bi-music-note"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="item-title">@item.Album?.Title</h6>
                                            <div class="item-details">
                                                <span class="text-muted">數量：@item.Quantity</span>
                                            </div>
                                            <div class="item-price">
                                                NT$ @((item.Album!.Price * item.Quantity).ToString("N0"))
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <hr>

                        <!-- 金額計算 -->
                        <div class="summary-row">
                            <span>商品總計</span>
                            <span>NT$ @Model.TotalAmount.ToString("N0")</span>
                        </div>
                        <div class="summary-row">
                            <span>運費</span>
                            <span class="text-success">免費</span>
                        </div>

                        <hr>

                        <div class="summary-row summary-total">
                            <span class="fw-bold">應付金額</span>
                            <span class="fw-bold text-primary fs-4">NT$ @Model.TotalAmount.ToString("N0")</span>
                        </div>

                        <!-- 提交按鈕 -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-2"></i>確認送出訂單
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>返回購物車
                            </a>
                        </div>

                        <!-- 安全提示 -->
                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-1"></i>您的資料經過加密保護
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- ==================== 門市選擇 Modal ==================== -->
<div class="modal fade" id="storeSelectionModal" tabindex="-1" aria-labelledby="storeSelectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="storeSelectionModalLabel">
                    <i class="bi bi-shop me-2"></i>選擇超商門市
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- 搜尋欄位 -->
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" id="store-search-input"
                               placeholder="搜尋門市名稱、地址或代號...">
                    </div>
                </div>

                <!-- 縣市篩選 -->
                <div class="mb-3">
                    <select class="form-select" id="store-city-filter">
                        <option value="">所有縣市</option>
                    </select>
                </div>

                <!-- 門市清單 -->
                <div id="store-list" class="list-group">
                    <!-- 門市項目將由 JavaScript 動態生成 -->
                </div>

                <!-- 無結果提示 -->
                <div id="no-stores-message" class="alert alert-info" style="display: none;">
                    <i class="bi bi-info-circle me-2"></i>
                    查無符合的門市，請調整搜尋條件
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cart.css" asp-append-version="true" />
}

@section Scripts {
    <!-- jQuery Validation -->
    <partial name="_ValidationScriptsPartial" />

    <!-- 購物車模組會自動處理結帳頁面的動態功能 -->

    <script>
        $(document).ready(function() {
            // 簡化驗證：完全依賴後端驗證（CheckoutViewModel.Validate）
            // 前端只保留基本的必填欄位檢查（收件人姓名、電話）

            // 監聽配送方式變更，清空不需要的欄位
            $('input[name="DeliveryMethod"]').on('change', function() {
                var deliveryMethod = $(this).val();

                // 根據配送方式清空不需要的欄位
                if (deliveryMethod === '0') {
                    // 宅配到府：清空門市欄位
                    $('#SevenElevenStoreCode, #SevenElevenStoreName, #SevenElevenStoreAddress').val('');
                    $('#FamilyMartStoreCode, #FamilyMartStoreName, #FamilyMartStoreAddress').val('');
                } else if (deliveryMethod === '1') {
                    // 7-11 超商取貨：清空地址和全家門市欄位
                    $('#City, #District, #PostalCode, #Address').val('');
                    $('#FamilyMartStoreCode, #FamilyMartStoreName, #FamilyMartStoreAddress').val('');
                } else if (deliveryMethod === '2') {
                    // 全家超商取貨：清空地址和 7-11 門市欄位
                    $('#City, #District, #PostalCode, #Address').val('');
                    $('#SevenElevenStoreCode, #SevenElevenStoreName, #SevenElevenStoreAddress').val('');
                }

                // 清空發票欄位（切換時重置）
                if ($('input[name="InvoiceType"]:checked').val() !== '1') {
                    $('#CompanyTaxId, #CompanyName').val('');
                }
                if ($('input[name="InvoiceType"]:checked').val() !== '2') {
                    $('#InvoiceCarrier').val('');
                }
            });

            // 監聽發票類型變更
            $('input[name="InvoiceType"]').on('change', function() {
                var invoiceType = $(this).val();

                // 清空不需要的發票欄位
                if (invoiceType !== '1') {
                    $('#CompanyTaxId, #CompanyName').val('');
                }
                if (invoiceType !== '2') {
                    $('#InvoiceCarrier').val('');
                }
            });

            // 頁面載入時觸發一次，清空不需要的欄位
            $('input[name="DeliveryMethod"]:checked').trigger('change');
        });
    </script>
}
