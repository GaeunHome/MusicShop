@inject MusicShop.Service.Services.Interfaces.IArtistService ArtistService
@inject MusicShop.Service.Services.Interfaces.IProductTypeService ProductTypeService
@inject Microsoft.Extensions.Options.IOptions<MusicShop.Web.Infrastructure.SiteSettings> SiteSettingsOptions
@{
    var artistGroups = await ArtistService.GetNavArtistGroupsAsync();
    var categoryTree = await ProductTypeService.GetNavCategoryTreeAsync();
    var siteSettings = SiteSettingsOptions.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteSettings.SiteName</title>

    <!-- SEO Meta 標籤 -->
    <meta name="description" content="@(ViewBag.MetaDescription ?? "MusicShop 線上音樂專輯商店 - K-POP 專輯、寫真、周邊商品")">
    <meta name="keywords" content="@(ViewBag.MetaKeywords ?? "K-POP,韓國專輯,音樂商店,偶像周邊")">

    <!-- Open Graph 社群分享標籤 -->
    <meta property="og:title" content="@(ViewBag.OgTitle ?? ViewBag.Title ?? "MusicShop")">
    <meta property="og:description" content="@(ViewBag.MetaDescription ?? "MusicShop 線上音樂專輯商店")">
    <meta property="og:type" content="@(ViewBag.OgType ?? "website")">
    <meta property="og:image" content="@(ViewBag.OgImage ?? "")">
    <meta property="og:site_name" content="MusicShop">

    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- CSS 變數（必須在所有自訂樣式之前載入） -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- 骨架載入動畫元件樣式 -->
    <link rel="stylesheet" href="~/css/components/skeleton.css" asp-append-version="true" />

    <!-- 微互動動畫樣式 -->
    <link rel="stylesheet" href="~/css/components/animations.css" asp-append-version="true" />

    <!-- 訂單狀態時間軸元件樣式 -->
    <link rel="stylesheet" href="~/css/components/order-timeline.css" asp-append-version="true" />

    @* 後台專屬樣式 *@
    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Admin")
    {
        <link rel="stylesheet" href="~/css/pages/admin.css" asp-append-version="true" />
    }

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-page="@ViewData["PageId"]">
    <header>
        <!-- 頂部紫色資訊列 -->
        <div class="top-info-bar">
            <div class="container">
                <div class="text-center py-2">
                    <span>🎵 MUSICSHOP FAMILY NO. @siteSettings.MembershipId</span>
                </div>
            </div>
        </div>

        <!-- Logo 與工具列 -->
        <div class="logo-bar">
            <div class="container">
                <div class="d-flex align-items-center justify-content-between py-3">
                    <!-- Logo 置中 -->
                    <div class="flex-fill d-flex align-items-center">
                        <button class="d-lg-none border-0 bg-transparent p-1"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#mainNavCollapse"
                                aria-controls="mainNavCollapse"
                                aria-expanded="false"
                                aria-label="開啟選單">
                            <i class="bi bi-list" style="font-size: 1.6rem; color: #555;"></i>
                        </button>
                    </div>
                    <a asp-controller="Home" asp-action="Index" class="logo-link">
                        <h2 class="logo-text mb-0">@siteSettings.SiteName</h2>
                    </a>
                    <!-- 右側圖示 -->
                    <div class="flex-fill d-flex justify-content-end align-items-center gap-3">
                        <!-- 用戶圖示 -->
                        <div class="user-dropdown-container">
                            <button class="nav-icon" id="userMenuToggle">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                    <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm12 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1v-1c0-1-1-4-6-4s-6 3-6 4v1a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12z"/>
                                </svg>
                            </button>
                            <!-- 用戶下拉選單 -->
                            <div class="user-dropdown-menu" id="userDropdownMenu">
                                @if (User.Identity!.IsAuthenticated)
                                {
                                    <div class="dropdown-section">
                                        <a asp-controller="Account" asp-action="Index" class="dropdown-link">我的帳戶</a>
                                        <a asp-controller="Order" asp-action="Index" class="dropdown-link">訂單查詢</a>
                                        <a href="#" class="dropdown-link">專屬優惠券</a>
                                        <a asp-controller="Wishlist" asp-action="Index" class="dropdown-link">收藏清單</a>
                                    </div>
                                    <div class="dropdown-divider"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                        <button type="button" class="dropdown-button secondary-button" onclick="confirmLogout()">登出</button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="dropdown-button primary-button">會員登入</a>
                                    <a asp-controller="Account" asp-action="Register" class="dropdown-button secondary-button">註冊新會員</a>
                                    <div class="dropdown-divider"></div>
                                    <div class="dropdown-section">
                                        <a asp-controller="Order" asp-action="Index" class="dropdown-link">訂單查詢</a>
                                        <a href="#" class="dropdown-link">專屬優惠券</a>
                                        <a asp-controller="Wishlist" asp-action="Index" class="dropdown-link">收藏清單</a>
                                    </div>
                                }
                            </div>
                        </div>
                        <!-- 購物車圖示 -->
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <a asp-controller="Cart" asp-action="Index" class="nav-icon cart-icon" aria-label="購物車">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                </svg>
                                @await Component.InvokeAsync("CartBadge")
                            </a>
                        }
                        else
                        {
                            <button type="button" class="nav-icon cart-icon" data-require-auth aria-label="購物車">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                </svg>
                            </button>
                        }
                        <!-- 搜尋圖示 -->
                        <button class="nav-icon" id="searchToggle">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 搜尋彈出框 -->
        <div class="search-overlay" id="searchOverlay">
            <div class="search-container">
                <form asp-controller="Album" asp-action="Index" method="get" class="search-form">
                    <input type="text" name="search" class="search-input" placeholder="搜尋專輯或藝人..." aria-label="搜尋商品" />
                    <button type="submit" class="search-submit-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                        </svg>
                    </button>
                </form>
                <button class="search-close-btn" id="searchClose">✕</button>
            </div>
        </div>

        <!-- 主選單 -->
        <nav class="main-nav">
            <div class="container">
                <div class="collapse" id="mainNavCollapse">
                    <ul class="nav-menu">
                        <li class="nav-menu-item">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-menu-item mega-dropdown dropdown">
                            <a asp-controller="Album" asp-action="Index">K-ARTIST</a>
                            <button class="d-lg-none nav-mobile-toggle" type="button"
                                    data-nav-mobile-toggle>
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="mega-menu">
                                <div class="container">
                                    <div class="row">
                                        @foreach (var group in artistGroups)
                                        {
                                            <div class="col-md-4">
                                                <a asp-controller="Album"
                                                   asp-action="Index"
                                                   asp-route-artistCategoryId="@group.CategoryId"
                                                   class="mega-menu-title-link">
                                                    <h6 class="mega-menu-title">@group.CategoryName</h6>
                                                </a>
                                                <ul class="mega-menu-list">
                                                    @foreach (var artist in group.Artists)
                                                    {
                                                        <li>
                                                            <a asp-controller="Album"
                                                               asp-action="Index"
                                                               asp-route-artistId="@artist.Id">
                                                                @artist.Name
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </li>
                        @foreach (var parent in categoryTree)
                        {
                            <li class="nav-menu-item dropdown">
                                <a asp-controller="Album" asp-action="Index" asp-route-parentProductTypeId="@parent.Id">@parent.Name</a>
                                <button class="d-lg-none nav-mobile-toggle" type="button"
                                        data-nav-mobile-toggle>
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    @if (parent.Children.Any())
                                    {
                                        @foreach (var child in parent.Children)
                                        {
                                            <li><a asp-controller="Album" asp-action="Index" asp-route-productTypeId="@child.Id">@child.Name</a></li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-muted px-3 py-2">尚無子分類</li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-menu-item">
                                <a asp-controller="Admin" asp-action="Index">後台管理</a>
                            </li>
                        }
                        <li class="nav-menu-item">
                            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @RenderSection("Banner", required: false)
    <div class="container">
        <main role="main" class="pb-5 mb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="footer-main py-5">
            <div class="container">
                <div class="row">
                    <!-- 關於 MusicShop -->
                    <div class="col-md-3 mb-4">
                        <h5 class="footer-title mb-3">關於 @siteSettings.SiteName</h5>
                        <ul class="list-unstyled footer-links">
                            <li><a asp-controller="Home" asp-action="Index">查詢</a></li> @* 首頁 *@
                            <li><a asp-controller="Home" asp-action="About">關於我們</a></li> @* 尚未建立 About Action *@
                            <li><a asp-controller="Account" asp-action="Index">我的帳戶</a></li> @* 會員中心 *@
                            <li><a asp-controller="Home" asp-action="RefundPolicy">退款政策</a></li> @* 尚未建立 RefundPolicy Action *@
                            <li><a asp-controller="Home" asp-action="Privacy">隱私政策</a></li> @* 已建立 *@
                            <li><a asp-controller="Home" asp-action="Terms">服務條款</a></li> @* 尚未建立 Terms Action *@
                        </ul>
                    </div>

                    <!-- 客服資訊 -->
                    <div class="col-md-6 mb-4">
                        <h5 class="footer-title mb-3">@siteSettings.SiteName 客服</h5>
                        <p class="footer-info mb-2">
                            <strong>客服專線：</strong>@siteSettings.CustomerServicePhone
                        </p>
                        <p class="footer-info mb-2">
                            <strong>客服時間：</strong>@siteSettings.CustomerServiceHours
                        </p>
                        <p class="footer-info mb-3">
                            <strong>信箱：</strong>@siteSettings.CustomerServiceEmail
                        </p>
                        <p class="footer-company-id mb-0">
                            <strong>統一編號：</strong>@siteSettings.CompanyTaxId</p>
                    </div>

                    <!-- 社交媒體 -->
                    <div class="col-md-3 mb-4 text-end">
                        <h5 class="footer-title mb-3">追蹤我們</h5>
                        <div class="footer-social">
                            @* Facebook 粉絲專頁連結 *@
                            <a href="@siteSettings.SocialMedia.Facebook" target="_blank" class="social-icon" aria-label="Facebook" title="Facebook 粉絲專頁">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                                    <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/>
                                </svg>
                            </a>
                            @* Instagram 帳號連結 *@
                            <a href="@siteSettings.SocialMedia.Instagram" target="_blank" class="social-icon" aria-label="Instagram" title="Instagram 帳號">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-instagram" viewBox="0 0 16 16">
                                    <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/>
                                </svg>
                            </a>
                            @* LINE 官方帳號連結 *@
                            <a href="@siteSettings.SocialMedia.LINE" target="_blank" class="social-icon" aria-label="LINE" title="LINE 官方帳號">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-line" viewBox="0 0 16 16">
                                    <path d="M8 0c4.411 0 8 2.912 8 6.492 0 1.433-.555 2.723-1.715 3.994-1.678 1.932-5.431 4.285-6.285 4.645-.83.35-.734-.197-.696-.413l.003-.018.114-.685c.027-.204.055-.521-.026-.723-.09-.223-.444-.339-.704-.395C2.846 12.39 0 9.701 0 6.492 0 2.912 3.59 0 8 0ZM5.022 7.686H3.497V4.918a.156.156 0 0 0-.155-.156H2.78a.156.156 0 0 0-.156.156v3.486c0 .041.017.08.044.107v.001l.002.002.002.002a.154.154 0 0 0 .108.043h2.242c.086 0 .155-.07.155-.156v-.56a.156.156 0 0 0-.155-.157Zm.791-2.924a.156.156 0 0 0-.156.156v3.486c0 .086.07.155.156.155h.562c.086 0 .155-.07.155-.155V4.918a.156.156 0 0 0-.155-.156h-.562Zm3.863 0a.156.156 0 0 0-.156.156v2.07L7.923 4.832a.17.17 0 0 0-.013-.015v-.001a.139.139 0 0 0-.01-.01l-.003-.003a.092.092 0 0 0-.011-.009h-.001L7.88 4.79l-.003-.002a.029.029 0 0 0-.005-.003l-.008-.005h-.002l-.003-.002-.01-.004-.004-.002a.093.093 0 0 0-.01-.003h-.002l-.003-.001-.009-.002h-.006l-.003-.001h-.004l-.002-.001h-.574a.156.156 0 0 0-.156.155v3.486c0 .086.07.155.156.155h.56c.087 0 .157-.07.157-.155v-2.07l1.6 2.16a.154.154 0 0 0 .039.038l.001.001.01.006.004.002a.066.066 0 0 0 .008.004l.007.003.005.002a.168.168 0 0 0 .01.003h.003a.155.155 0 0 0 .04.006h.56c.087 0 .157-.07.157-.155V4.918a.156.156 0 0 0-.156-.156h-.561Zm3.815.717v-.56a.156.156 0 0 0-.155-.157h-2.242a.155.155 0 0 0-.108.044h-.001l-.001.002-.002.003a.155.155 0 0 0-.044.107v3.486c0 .041.017.08.044.107l.002.003.002.002a.155.155 0 0 0 .108.043h2.242c.086 0 .155-.07.155-.156v-.56a.156.156 0 0 0-.155-.157H11.81v-.589h1.525c.086 0 .155-.07.155-.156v-.56a.156.156 0 0 0-.155-.157H11.81v-.589h1.525c.086 0 .155-.07.155-.156Z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <div class="footer-bottom py-3">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-12 text-center">
                        <p class="mb-0">
                            Copyright &copy; <strong>@siteSettings.SiteName</strong> All Rights Reserved. Designed by <strong>HOU WEN CHIA</strong>.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 回到頂端按鈕 -->
        <button id="backToTop" class="back-to-top" onclick="scrollToTop()" title="回到頂端">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z"/>
            </svg>
        </button>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 核心功能模組 -->
    <script src="~/js/core/site.js" asp-append-version="true"></script>
    <script src="~/js/core/notifications.js" asp-append-version="true"></script>
    <script src="~/js/core/common.js" asp-append-version="true"></script>

    <!-- 工具模組（必須在功能模組之前載入）-->
    <script src="~/js/utils/ajax-helper.js" asp-append-version="true"></script>
    <script src="~/js/utils/toast-helper.js" asp-append-version="true"></script>
    <script src="~/js/utils/price-formatter.js" asp-append-version="true"></script>

    <!-- 工具模組：圖片淡入載入器 -->
    <script src="~/js/utils/image-loader.js" asp-append-version="true"></script>

    <!-- 購物車 Badge 即時更新（全域共用，因為導覽列在每頁都有） -->
    <script src="~/js/features/cart/cart-badge.js" asp-append-version="true"></script>

    <!-- 前台功能模組 -->
