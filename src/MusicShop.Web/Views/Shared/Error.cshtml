@model ErrorViewModel
@{
    ViewData["Title"] = "錯誤";
    Layout = "_Layout";

    /* 取得錯誤資訊，若 ViewBag 為 null 則使用預設值 */
    var statusCode = ViewBag.StatusCode as int? ?? 500;
    var errorTitle = ViewBag.ErrorTitle as string ?? "系統發生錯誤";
    var errorMessage = ViewBag.ErrorMessage as string ?? "很抱歉，處理您的請求時發生了未預期的錯誤，請稍後再試。";

    /* 根據狀態碼選擇對應的 Bootstrap Icon */
    var iconClass = statusCode switch
    {
        400 => "bi-exclamation-circle",
        401 => "bi-shield-lock",
        403 => "bi-ban",
        404 => "bi-search",
        408 => "bi-clock-history",
        429 => "bi-hourglass-split",
        500 => "bi-gear-wide-connected",
        502 => "bi-cloud-slash",
        503 => "bi-tools",
        _ => "bi-exclamation-triangle"
    };
}

@section Styles {
    <style>
        /* 錯誤頁面容器 */
        .error-page {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 60vh;
            text-align: center;
            padding: 2rem 1rem;
        }

        /* 錯誤圖示 */
        .error-icon {
            font-size: 5rem;
            color: #b19cd9;
            margin-bottom: 1rem;
            animation: error-icon-pulse 2s ease-in-out infinite;
        }

        @@keyframes error-icon-pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.08); opacity: 0.85; }
        }

        /* 狀態碼 */
        .error-status-code {
            font-size: 6rem;
            font-weight: 800;
            color: #b19cd9;
            line-height: 1;
            margin-bottom: 0.5rem;
            letter-spacing: -2px;
        }

        /* 錯誤標題 */
        .error-title {
            font-size: 1.75rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 0.75rem;
        }

        /* 錯誤訊息 */
        .error-message {
            font-size: 1.05rem;
            color: #777;
            max-width: 480px;
            margin: 0 auto 2rem;
            line-height: 1.6;
        }

        /* 按鈕群組 */
        .error-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        /* 主要按鈕（返回首頁） */
        .error-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.75rem;
            background: linear-gradient(135deg, #b19cd9, #9b84c4);
            color: #fff;
            border: none;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(177, 156, 217, 0.35);
        }

        .error-btn-primary:hover {
            background: linear-gradient(135deg, #9b84c4, #8570b0);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(177, 156, 217, 0.5);
        }

        /* 次要按鈕（返回上一頁） */
        .error-btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.75rem;
            background: transparent;
            color: #b19cd9;
            border: 2px solid #b19cd9;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .error-btn-secondary:hover {
            background: rgba(177, 156, 217, 0.1);
            color: #9b84c4;
            border-color: #9b84c4;
            transform: translateY(-2px);
        }

        /* Request ID（僅開發環境顯示） */
        .error-request-id {
            margin-top: 2rem;
            padding: 0.75rem 1.25rem;
            background: #f8f8fa;
            border-radius: 8px;
            font-size: 0.85rem;
            color: #999;
        }

        .error-request-id code {
            color: #b19cd9;
            font-weight: 500;
        }

        /* 裝飾分隔線 */
        .error-divider {
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #b19cd9, #d4c5f0);
            border: none;
            border-radius: 2px;
            margin: 1rem auto 1.5rem;
        }

        /* 響應式調整 */
        @@media (max-width: 576px) {
            .error-status-code {
                font-size: 4rem;
            }

            .error-icon {
                font-size: 3.5rem;
            }

            .error-title {
                font-size: 1.35rem;
            }

            .error-message {
                font-size: 0.95rem;
            }

            .error-actions {
                flex-direction: column;
                align-items: center;
            }

            .error-btn-primary,
            .error-btn-secondary {
                width: 100%;
                max-width: 280px;
                justify-content: center;
            }
        }
    </style>
}

<div class="error-page">
    <!-- 錯誤圖示 -->
    <div class="error-icon">
        <i class="bi @iconClass"></i>
    </div>

    <!-- 狀態碼 -->
    <div class="error-status-code">@statusCode</div>

    <!-- 裝飾分隔線 -->
    <hr class="error-divider" />

    <!-- 錯誤標題 -->
    <h1 class="error-title">@errorTitle</h1>

    <!-- 錯誤訊息 -->
    <p class="error-message">@errorMessage</p>

    <!-- 操作按鈕 -->
    <div class="error-actions">
        <a asp-controller="Home" asp-action="Index" class="error-btn-primary">
            <i class="bi bi-house-door"></i>
            返回首頁
        </a>
        <button type="button" class="error-btn-secondary" onclick="history.back()">
            <i class="bi bi-arrow-left"></i>
            返回上一頁
        </button>
    </div>

    @* Request ID 僅在開發環境中顯示，協助除錯 *@
    @if (Model?.ShowRequestId == true)
    {
        <div class="error-request-id">
            <strong>Request ID：</strong><code>@Model.RequestId</code>
        </div>
    }
</div>
