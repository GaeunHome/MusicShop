@model AlbumCardViewModel
@{
    var wishlistIds = ViewData["WishlistIds"] as HashSet<int> ?? new HashSet<int>();
    bool isInWishlist = wishlistIds.Contains(Model.Id);
}

<!-- 商品卡片 -->
<div class="col" role="article" aria-label="@Model.Title">
    <div class="product-item">
        <div class="product-image-wrapper">
            <a asp-controller="Album" asp-action="Detail" asp-route-id="@Model.Id"
               class="product-image-link" aria-label="查看 @Model.Title 詳細資訊"></a>

            @if (Model.HasCoverImage)
            {
                <!-- 商品圖片，使用延遲載入 -->
                <img src="@Model.CoverImageUrl" class="product-image" alt="@Model.Title 專輯封面" loading="lazy">
            }
            else
            {
                <div class="product-image d-flex align-items-center justify-content-center album-placeholder-bg">
                    <span class="text-white fs-1">♪</span>
                </div>
            }

            @if (Model.IsSoldOut)
            {
                <!-- 已售完遮罩覆蓋 -->
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center sold-out-overlay">
                    <span class="badge bg-danger fs-6 px-3 py-2">已售完</span>
                </div>
            }
            else if (Model.IsLowStock)
            {
                <!-- 低庫存警示標籤 -->
                <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2" style="z-index: 10;">@Model.StockStatusText</span>
            }

            <!-- 懸停按鈕 -->
            <div class="product-overlay">
                <div class="overlay-buttons d-flex gap-2 mb-2">
                    <!-- 查看商品 -->
                    <a asp-controller="Album" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-white overlay-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                        </svg>
                    </a>

                    <!-- 加入購物車 -->
                    @if (Model.IsInStock)
                    {
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <button type="button" class="btn btn-purple overlay-btn"
                                    data-bs-toggle="modal" data-bs-target="#addToCartModal"
                                    data-album-id="@Model.Id"
                                    data-album-title="@Model.Title"
                                    data-album-artist="@(Model.ArtistName ?? "未設定藝人")"
                                    data-album-price="@Model.Price"
                                    data-album-stock="@Model.Stock"
                                    data-album-image="@Model.CoverImageUrl">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-purple overlay-btn" data-require-auth>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                </svg>
                            </button>
                        }
                    }

                    <!-- 加入收藏 -->
                    <!-- 收藏按鈕 -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <button type="button"
                                class="btn btn-white overlay-btn wishlist-toggle @(isInWishlist ? "wishlisted" : "")"
                                data-album-id="@Model.Id"
                                aria-pressed="@(isInWishlist ? "true" : "false")"
                                aria-label="@(isInWishlist ? "取消收藏" : "加入收藏") @Model.Title"
                                title="@(isInWishlist ? "取消收藏" : "加入收藏")">
                            <i class="bi @(isInWishlist ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-white overlay-btn" data-require-auth
                                aria-label="登入後加入收藏" title="登入後加入收藏">
                            <i class="bi bi-heart"></i>
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="product-info mt-3">
            <a asp-controller="Album" asp-action="Detail" asp-route-id="@Model.Id" class="text-decoration-none text-dark">
                <h6 class="product-title mb-2">@Model.Title</h6>
            </a>
            <p class="product-price mb-0">NT$@Model.FormattedPrice</p>
        </div>
    </div>
</div>
