@model AlbumCardViewModel
@{
    var wishlistIds = ViewData["WishlistIds"] as HashSet<int> ?? new HashSet<int>();
    bool isInWishlist = wishlistIds.Contains(Model.Id);
}

<!-- 商品列表項目 -->
<div class="product-list-item" role="article" aria-label="@Model.Title">
    <div class="position-relative">
        @if (Model.HasCoverImage)
        {
            <!-- 商品圖片，使用延遲載入 -->
            <img src="@Model.CoverImageUrl" class="product-list-image" alt="@Model.Title 專輯封面" loading="lazy">
        }
        else
        {
            <div class="product-list-image-placeholder">
                <span class="text-white music-note-icon-lg">♪</span>
            </div>
        }

        @if (Model.IsSoldOut)
        {
            <span class="position-absolute top-0 start-0 badge bg-danger m-1 badge-stock-sm">已售完</span>
        }
        else if (Model.IsLowStock)
        {
            <span class="position-absolute top-0 start-0 badge bg-warning text-dark m-1 badge-stock-sm">@Model.StockStatusText</span>
        }
    </div>

    <div class="product-list-info">
        <a asp-controller="Album" asp-action="Detail" asp-route-id="@Model.Id" class="product-list-title">@Model.Title</a>
        <div class="product-list-artist">@(Model.ArtistName ?? "未設定藝人")</div>
        <div class="product-list-price mt-2">NT$@Model.FormattedPrice</div>
    </div>

    <div class="product-list-actions">
        @if (Model.IsInStock)
        {
            @if (User.Identity!.IsAuthenticated)
            {
                <button type="button" class="btn btn-primary"
                        data-bs-toggle="modal" data-bs-target="#addToCartModal"
                        data-album-id="@Model.Id"
                        data-album-title="@Model.Title"
                        data-album-artist="@(Model.ArtistName ?? "未設定藝人")"
                        data-album-price="@Model.Price"
                        data-album-stock="@Model.Stock"
                        data-album-image="@Model.CoverImageUrl">
                    加入購物車
                </button>
            }
            else
            {
                <button type="button" class="btn btn-primary" data-require-auth>加入購物車</button>
            }
        }
        else
        {
            <button type="button" class="btn btn-secondary" disabled>商品已售完</button>
        }

        <!-- 收藏按鈕 -->
        @if (User.Identity!.IsAuthenticated)
        {
            <button type="button"
                    class="btn-wishlist wishlist-toggle @(isInWishlist ? "wishlisted" : "")"
                    data-album-id="@Model.Id"
                    aria-pressed="@(isInWishlist ? "true" : "false")"
                    aria-label="@(isInWishlist ? "取消收藏" : "加入收藏") @Model.Title"
                    title="@(isInWishlist ? "取消收藏" : "加入收藏")">
                <i class="bi @(isInWishlist ? "bi-heart-fill text-danger" : "bi-heart")"></i>
            </button>
        }
        else
        {
            <button type="button" class="btn-wishlist" data-require-auth
                    aria-label="登入後加入收藏" title="登入後加入收藏">
                <i class="bi bi-heart"></i>
            </button>
        }
    </div>
</div>
