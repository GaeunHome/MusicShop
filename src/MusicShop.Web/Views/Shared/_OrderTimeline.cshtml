@*
    訂單狀態時間軸元件 (_OrderTimeline.cshtml)
    接收 OrderTimelineViewModel，以視覺化方式呈現訂單進度。
    所有業務邏輯（進度計算、步驟狀態判斷）已在 ViewModel 的 Create 方法中完成，
    View 僅負責顯示。

    使用方式：
    @await Html.PartialAsync("_OrderTimeline", OrderTimelineViewModel.Create(Model.Status))
*@
@model MusicShop.Service.ViewModels.Order.OrderTimelineViewModel

<div class="card order-timeline-card mb-4">
    <div class="card-body">
        <div class="order-timeline @(Model.IsCancelled ? "is-cancelled" : "")">
            @* 進度條（動態寬度） *@
            <div class="timeline-progress" style="width: @(Model.ProgressPercent)%;"></div>

            @foreach (var step in Model.Steps)
            {
                <div class="timeline-step @step.StepClass">
                    <div class="timeline-icon">
                        <i class="bi @step.IconClass"></i>
                    </div>
                    <span class="timeline-label">@step.Label</span>
                    <span class="timeline-desc">@step.Description</span>
                </div>
            }
        </div>
    </div>
</div>
