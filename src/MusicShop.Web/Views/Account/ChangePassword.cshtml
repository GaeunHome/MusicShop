@model MusicShop.Service.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "更新密碼";
}

<div id="account-edit-page" class="container my-5">
    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">首頁</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Account" asp-action="Index">我的帳戶</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">更新密碼</li>
        </ol>
    </nav>

    <h1 class="page-title mb-4">更新密碼</h1>

    <div class="row">
        <!-- 左側選單（桌面版） -->
        <div class="col-lg-3 d-none d-lg-block">
            @await Html.PartialAsync("_AccountMenu")
        </div>

        <!-- 右側內容 -->
        <div class="col-lg-9 col-12">
            <!-- 手機版選單 -->
            <div class="mobile-menu d-lg-none mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        更新密碼
                    </button>
                    <ul class="dropdown-menu w-100">
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Index">我的帳戶</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Edit">更新個人資訊</a>
                        </li>
                        <li>
                            <a class="dropdown-item active" asp-controller="Account" asp-action="ChangePassword">更新密碼</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Order" asp-action="Index">訂單查詢</a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- 成功訊息 -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- 更新密碼表單 -->
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">目前密碼</label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">新密碼</label>
                            <input asp-for="NewPassword" class="form-control" type="password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <small class="form-text text-muted">密碼長度至少需要 6 個字元</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">確認新密碼</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary">更新密碼</button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">取消</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
