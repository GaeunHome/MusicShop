@{
    ViewData["Title"] = "驗證您的 Email";
}

<partial name="_TempDataNotifications" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check icon-confirmation-success"></i>
                    </div>
                    <h3 class="card-title mb-3">請驗證您的 Email</h3>
                    <p class="text-muted">
                        我們已寄送驗證信至<br>
                        <strong>@ViewBag.Email</strong>
                    </p>
                    <p class="text-muted small">
                        請點擊信中的驗證連結完成註冊。<br>
                        如果沒有收到信件，請檢查垃圾郵件資料夾。
                    </p>

                    <hr class="my-4">

                    <form asp-action="ResendConfirmation" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@ViewBag.UserId" />
                        <button type="submit" class="btn btn-outline-primary btn-sm">
                            重新寄送驗證信
                        </button>
                    </form>

                    <div class="mt-3">
                        <small><a asp-action="Login">返回登入頁</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
