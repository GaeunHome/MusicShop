@model MusicShop.Service.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "登入";
}

<!-- 引用共用的 TempData 通知元件（SweetAlert2 彈跳視窗） -->
<partial name="_TempDataNotifications" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-4">會員登入</h3>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label required"></label>
                            <input asp-for="Email" class="form-control" placeholder="請輸入Email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label required"></label>
                            <input asp-for="Password" class="form-control" placeholder="請輸入密碼" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">登入</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <small><a asp-action="ForgotPassword">忘記密碼？</a></small>
                    </div>

                    <div class="text-center mt-2">
                        <small>還沒有帳號？<a asp-action="Register">立即註冊</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}