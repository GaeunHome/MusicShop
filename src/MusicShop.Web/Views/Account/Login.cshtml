@model MusicShop.Service.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "登入";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/captcha.css" />
}

<!-- 引用共用的 TempData 通知元件（SweetAlert2 彈跳視窗） -->
<partial name="_TempDataNotifications" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-4">會員登入</h3>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label required"></label>
                            <input asp-for="Email" class="form-control" placeholder="請輸入Email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label required"></label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" placeholder="請輸入密碼" />
                                <button class="password-toggle" type="button" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CaptchaCode" class="form-label required"></label>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <img id="captchaImage"
                                     src="@Url.Action("CaptchaImage", "Account")"
                                     alt="驗證碼" class="captcha-image rounded" />
                                <button type="button" id="refreshCaptcha"
                                        class="btn btn-outline-secondary btn-sm"
                                        title="重新產生驗證碼">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                            <input asp-for="CaptchaCode" class="form-control"
                                   placeholder="請輸入上方驗證碼" autocomplete="off" maxlength="6" />
                            <span asp-validation-for="CaptchaCode" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">登入</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <small><a asp-action="ForgotPassword">忘記密碼？</a></small>
                    </div>

                    <div class="text-center mt-2">
                        <small>還沒有帳號？<a asp-action="Register">立即註冊</a></small>
                    </div>

                    @if (ViewBag.ExternalProviders != null && ((IEnumerable<string>)ViewBag.ExternalProviders).Any())
                    {
                        <hr class="my-3" />
                        <p class="text-center text-muted small mb-3">或使用社群帳號登入</p>
                        <div class="d-grid gap-2">
                            @foreach (var provider in (IEnumerable<string>)ViewBag.ExternalProviders)
                            {
                                <form asp-action="ExternalLogin" method="post">
                                    <input type="hidden" name="provider" value="@provider" />
                                    @if (provider == "Google")
                                    {
                                        <button type="submit" class="btn btn-danger w-100">
                                            <i class="bi bi-google me-2"></i>使用 Google 登入
                                        </button>
                                    }
                                    else if (provider == "LINE")
                                    {
                                        <button type="submit" class="btn btn-line w-100">
                                            <i class="bi bi-chat-fill me-2"></i>使用 LINE 登入
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-outline-secondary w-100">
                                            使用 @provider 登入
                                        </button>
                                    }
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/features/auth/captcha.js"></script>
}