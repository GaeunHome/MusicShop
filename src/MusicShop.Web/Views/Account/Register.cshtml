@model MusicShop.Service.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "註冊";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-4">會員註冊</h3>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label required"></label>
                            <input asp-for="FullName" class="form-control" placeholder="請輸入姓名" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label required"></label>
                            <input asp-for="Email" class="form-control" placeholder="請輸入Email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label required"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="請輸入手機號碼（例如：0912345678）" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Birthday" class="form-label required"></label>
                            <input asp-for="Birthday" class="form-control" type="date" />
                            <span asp-validation-for="Birthday" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label required">性別</label>
                            <div>
                                <div class="form-check form-check-inline">
                                    <input asp-for="Gender" class="form-check-input" type="radio" value="1" id="genderMale" />
                                    <label class="form-check-label" for="genderMale">男性</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input asp-for="Gender" class="form-check-input" type="radio" value="2" id="genderFemale" />
                                    <label class="form-check-label" for="genderFemale">女性</label>
                                </div>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger small d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label required"></label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" placeholder="請輸入密碼（至少6個字元）" />
                                <button class="password-toggle" type="button" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label required"></label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="請再輸入一次密碼" />
                                <button class="password-toggle" type="button" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">註冊</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <small>已有帳號？<a asp-action="Login">立即登入</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
