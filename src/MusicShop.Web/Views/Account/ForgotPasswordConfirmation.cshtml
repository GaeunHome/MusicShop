@{
    ViewData["Title"] = "密碼重設信已寄出";
}

<partial name="_TempDataNotifications" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-paper" style="font-size: 3rem; color: #007bff;"></i>
                    </div>
                    <h3 class="card-title mb-3">請查看您的信箱</h3>
                    <p class="text-muted">
                        如果該 Email 已註冊帳號，我們已寄送密碼重設連結。<br>
                        請點擊信中的連結重設您的密碼。
                    </p>
                    <p class="text-muted small">
                        如果沒有收到信件，請檢查垃圾郵件資料夾。
                    </p>

                    <div class="mt-4">
                        <a asp-action="Login" class="btn btn-outline-primary">返回登入</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
