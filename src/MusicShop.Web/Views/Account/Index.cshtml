@model MusicShop.Service.ViewModels.Account.AccountIndexViewModel
@{
    ViewData["Title"] = "我的帳戶";
    ViewData["PageId"] = "account-index";
}

<!-- 引用共用的 TempData 通知元件 -->
<partial name="_TempDataNotifications" />

<div id="account-page" class="container my-5">
    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">首頁</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">我的帳戶</li>
        </ol>
    </nav>

    <h1 class="page-title mb-4">我的帳戶</h1>

    <div class="row">
        <!-- 左側選單（桌面版） -->
        <div class="col-lg-3 d-none d-lg-block">
            @await Html.PartialAsync("_AccountMenu")
        </div>

        <!-- 右側內容 -->
        <div class="col-lg-9 col-12">
            <!-- 手機版選單 -->
            <div class="mobile-menu d-lg-none mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        我的帳戶
                    </button>
                    <ul class="dropdown-menu w-100">
                        <li>
                            <a class="dropdown-item active" asp-controller="Account" asp-action="Index">我的帳戶</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Edit">更新個人資訊</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">更新密碼</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="TwoFactorAuthentication">兩步驟驗證</a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Order" asp-action="Index">訂單查詢</a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- 個人資料完整度提醒 -->
            @if (!Model.IsProfileComplete)
            {
                <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>個人資料尚未完整</strong> — 缺少：@string.Join("、", Model.MissingProfileItems)。
                    <a asp-action="Edit" class="alert-link">前往補充</a>，享受完整的購物體驗與生日優惠。
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- 會員資訊卡片 -->
            <div class="account-info-card card mb-4">
                <div class="card-body">
                    <!-- 頂部：姓名與登出 -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="user-name mb-0">@Model.FullName</h2>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">登出</button>
                        </form>
                    </div>

                    <!-- 查看個人資訊按鈕 -->
                    <div class="mb-3">
                        <a asp-action="Edit" class="btn btn-outline-primary btn-sm">查看個人資訊</a>
                    </div>

                    <!-- 安全性 -->
                    <div class="mb-3 d-flex align-items-center">
                        <span class="text-muted me-2">兩步驟驗證：</span>
                        @if (Model.TwoFactorEnabled)
                        {
                            <span class="badge bg-success"><i class="bi bi-shield-check"></i> 已啟用</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">未啟用</span>
                            <a asp-action="TwoFactorAuthentication" class="btn btn-outline-primary btn-sm ms-2">立即設定</a>
                        }
                    </div>

                    <!-- 購物統計 -->
                    <div class="shopping-stats">
                        <div class="stat-item">
                            <span class="stat-label">總累計消費金額</span>
                            <span class="stat-value">NT$@Model.TotalSpent.ToString("N0")</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label">總訂單數</span>
                            <span class="stat-value">@Model.TotalOrders 筆 (約 NT$0)</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 近期訂單 -->
            <div class="recent-orders">
                <h5 class="mb-3">近期訂單</h5>

                @if (Model.RecentOrders.Any())
                {
                    <div class="card">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>訂單編號</th>
                                        <th>訂單日期</th>
                                        <th>總金額</th>
                                        <th>付款狀態</th>
                                        <th>配送狀態</th>
                                        <th>訂單狀態</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id" class="text-decoration-none">
                                                    訂單編號 #@order.Id
                                                </a>
                                            </td>
                                            <td>訂單日期 @order.FormattedOrderDate</td>
                                            <td>NT$@order.FormattedFinalAmount</td>
                                            <td>
                                                <span>@order.PaymentStatusText</span>
                                            </td>
                                            <td>
                                                @if (order.IsDelivered)
                                                {
                                                    <span class="badge bg-info">@order.DeliveryStatusText</span>
                                                }
                                                else if (order.IsCompleted)
                                                {
                                                    <span class="badge bg-success">@order.DeliveryStatusText</span>
                                                }
                                                else
                                                {
                                                    <span>@order.DeliveryStatusText</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(order.FirstItemTitle))
                                                {
                                                    <div>@order.FirstItemTitle</div>
                                                    <small class="text-muted">數量：@order.FirstItemQuantity</small>
                                                }
                                                @if (order.TotalItemCount > 1)
                                                {
                                                    <small class="text-muted d-block">還有 @(order.TotalItemCount - 1) 項...</small>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <a asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">
                                                    查看詳情
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        目前沒有訂單記錄
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account.css" asp-append-version="true" />
}
