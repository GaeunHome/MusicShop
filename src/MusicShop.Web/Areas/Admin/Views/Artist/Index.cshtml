@model IReadOnlyList<MusicShop.Service.ViewModels.Admin.ArtistListItemViewModel>
@{
    ViewData["Title"] = "藝人管理";
    ViewData["PageId"] = "admin-artists";

    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var selectedCategoryId = (int?)ViewBag.SelectedCategoryId;
    var selectedIsActive = (bool?)ViewBag.SelectedIsActive;
}

@* 頁面標題 *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">藝人管理</h3>
            <small class="text-muted">共 @totalCount 位藝人</small>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> 新增藝人
        </a>
    </div>

    @* 篩選列 *@
    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" asp-action="Index" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-0">藝人分類</label>
                    <select name="categoryId" class="form-select form-select-sm admin-filter-w-md">
                        <option value="">全部分類</option>
                        @if (ViewBag.ArtistCategories is Microsoft.AspNetCore.Mvc.Rendering.SelectList categories)
                        {
                            @foreach (var item in categories)
                            {
                                <option value="@item.Value" selected="@(item.Value == selectedCategoryId?.ToString())">
                                    @item.Text
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-0">上架狀態</label>
                    <select name="isActive" class="form-select form-select-sm admin-filter-w-sm">
                        <option value="">全部</option>
                        <option value="true" selected="@(selectedIsActive == true)">上架中</option>
                        <option value="false" selected="@(selectedIsActive == false)">已下架</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-funnel"></i> 篩選
                    </button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-lg"></i> 清除
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">目前沒有符合條件的藝人資料</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="admin-col-id">ID</th>
                                <th>藝人名稱</th>
                                <th>分類</th>
                                <th class="admin-col-count text-center">商品數</th>
                                <th class="admin-col-order text-center">排序</th>
                                <th class="admin-col-status text-center">狀態</th>
                                <th class="admin-col-actions text-center">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var artist in Model)
                            {
                                <tr class="@(!artist.IsActive ? "table-secondary" : "")">
                                    <td class="text-muted">@artist.Id</td>
                                    <td>
                                        <span class="fw-bold @(!artist.IsActive ? "text-muted" : "")">
                                            @artist.Name
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@(artist.ArtistCategoryName ?? "未分類")</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@artist.AlbumCount</span>
                                    </td>
                                    <td class="text-center text-muted">@artist.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (artist.IsActive)
                                        {
                                            <span class="badge bg-success">上架中</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">已下架</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@artist.Id"
                                           class="btn btn-sm btn-outline-primary">編輯</a>
                                        <form asp-action="ToggleActive" asp-route-id="@artist.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm @(artist.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                                @(artist.IsActive ? "下架" : "上架")
                                            </button>
                                        </form>
                                        <form asp-action="Delete" asp-route-id="@artist.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('確定要刪除藝人「@artist.Name」嗎？');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* 分頁導覽 *@
    @await Html.PartialAsync("_Pagination")
}
