@model MusicShop.Service.ViewModels.Admin.CouponIssueViewModel
@{
    ViewData["Title"] = "發放優惠券";
}

<div>
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← 返回列表</a>
        <h3 class="mb-0">🎁 發放優惠券</h3>
    </div>

    <div class="alert alert-info">
        發放優惠券：<strong>@Model.CouponName</strong>
    </div>

    <form asp-action="Issue" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CouponId" />
        <input type="hidden" asp-for="CouponName" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

        <div class="mb-3">
            <label asp-for="UserEmail" class="form-label fw-bold">使用者 Email <span class="text-danger">*</span></label>
            <input asp-for="UserEmail" class="form-control" type="email" placeholder="user@example.com">
            <span asp-validation-for="UserEmail" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">確認發放</button>
            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
