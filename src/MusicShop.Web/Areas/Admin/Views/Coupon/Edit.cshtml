@model MusicShop.Service.ViewModels.Admin.CouponFormViewModel
@{
    ViewData["Title"] = "編輯優惠券";
}

<div>
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← 返回列表</a>
        <h3 class="mb-0">🎫 編輯優惠券</h3>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

        <div class="mb-3">
            <label asp-for="Code" class="form-label fw-bold">兌換碼 <span class="text-danger">*</span></label>
            <input asp-for="Code" class="form-control text-uppercase">
            <span asp-validation-for="Code" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">優惠券名稱 <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control">
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold">描述</label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="DiscountType" class="form-label fw-bold">折扣類型</label>
                <select asp-for="DiscountType" class="form-select">
                    <option value="1">固定金額折扣</option>
                    <option value="2">百分比折扣</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="DiscountValue" class="form-label fw-bold">折扣值</label>
                <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" min="0.01">
                <span asp-validation-for="DiscountValue" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="MaxDiscountAmount" class="form-label fw-bold">最高折扣上限</label>
                <input asp-for="MaxDiscountAmount" class="form-control" type="number" step="0.01" min="0">
            </div>
            <div class="col-md-6">
                <label asp-for="ValidDays" class="form-label fw-bold">有效天數</label>
                <input asp-for="ValidDays" class="form-control" type="number" min="1" max="365">
            </div>
        </div>

        <div class="mb-3">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox">
                <label asp-for="IsActive" class="form-check-label">啟用</label>
            </div>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsRedeemable" class="form-check-input" type="checkbox">
                <label asp-for="IsRedeemable" class="form-check-label">允許兌換碼兌換</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">儲存</button>
            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
