@model MusicShop.Service.ViewModels.Admin.CouponFormViewModel
@{
    ViewData["Title"] = "新增優惠券";
}

<div>
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← 返回列表</a>
        <h3 class="mb-0">🎫 新增優惠券</h3>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

        <div class="mb-3">
            <label asp-for="Code" class="form-label fw-bold">兌換碼 <span class="text-danger">*</span></label>
            <input asp-for="Code" class="form-control text-uppercase" placeholder="例：WELCOME2026">
            <span asp-validation-for="Code" class="text-danger small"></span>
            <div class="form-text">英數大寫，將自動轉為大寫</div>
        </div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">優惠券名稱 <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="例：新會員折扣">
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold">描述</label>
            <textarea asp-for="Description" class="form-control" rows="2" placeholder="優惠券說明（選填）"></textarea>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="DiscountType" class="form-label fw-bold">折扣類型 <span class="text-danger">*</span></label>
                <select asp-for="DiscountType" class="form-select">
                    <option value="1">固定金額折扣</option>
                    <option value="2">百分比折扣</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="DiscountValue" class="form-label fw-bold">折扣值 <span class="text-danger">*</span></label>
                <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" min="0.01">
                <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                <div class="form-text">固定金額：折扣金額（元）/ 百分比：折扣比例（例：10 = 折 10%）</div>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="MaxDiscountAmount" class="form-label fw-bold">最高折扣上限</label>
                <input asp-for="MaxDiscountAmount" class="form-control" type="number" step="0.01" min="0" placeholder="留空 = 不限">
                <div class="form-text">僅百分比折扣時生效</div>
            </div>
            <div class="col-md-6">
                <label asp-for="ValidDays" class="form-label fw-bold">有效天數</label>
                <input asp-for="ValidDays" class="form-control" type="number" min="1" max="365" value="30">
            </div>
        </div>

        <div class="mb-3">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                <label asp-for="IsActive" class="form-check-label">啟用</label>
            </div>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsRedeemable" class="form-check-input" type="checkbox">
                <label asp-for="IsRedeemable" class="form-check-label">允許兌換碼兌換</label>
            </div>
            <div class="form-text">啟用後使用者可輸入兌換碼自行領取</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">新增</button>
            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
