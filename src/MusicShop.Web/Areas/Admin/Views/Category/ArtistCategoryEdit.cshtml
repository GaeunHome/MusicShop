@model MusicShop.Service.ViewModels.Admin.ArtistCategoryFormViewModel
@{
    ViewData["Title"] = "編輯藝人分類";
}

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">✏️ 編輯藝人分類</div>
                <div class="card-body">
                    <form asp-action="ArtistCategoryEdit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label required">分類名稱</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">描述（選填）</label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">排序順序</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" />
                            <small class="text-muted">數字越小排序越前面</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">← 取消</a>
                            <button type="submit" class="btn btn-primary">儲存變更</button>
                        </div>
                    </form>
                </div>
            </div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
