@model MusicShop.Service.ViewModels.Admin.FeaturedArtistFormViewModel
@{
    ViewData["Title"] = "編輯精選藝人";
}

<div>
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← 返回列表</a>
        <h3 class="mb-0">⭐ 編輯精選藝人</h3>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

        <!-- 選擇藝人 -->
        <div class="mb-3">
            <label asp-for="ArtistId" class="form-label fw-bold">藝人 <span class="text-danger">*</span></label>
            <select asp-for="ArtistId" asp-items="ViewBag.Artists" class="form-select">
                <option value="">── 請選擇藝人 ──</option>
            </select>
            <span asp-validation-for="ArtistId" class="text-danger small"></span>
        </div>

        <!-- 顯示順序 -->
        <div class="mb-3">
            <label asp-for="DisplayOrder" class="form-label fw-bold">顯示順序</label>
            <input asp-for="DisplayOrder" class="form-control" type="number" min="0">
        </div>

        <!-- 是否啟用 -->
        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox">
                <label asp-for="IsActive" class="form-check-label">顯示中</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">儲存</button>
            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
