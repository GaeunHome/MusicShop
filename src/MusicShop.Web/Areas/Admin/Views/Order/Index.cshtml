@model MusicShop.Library.Helpers.PagedResult<MusicShop.Service.ViewModels.Admin.AdminOrderListItemViewModel>
@{
    ViewData["Title"] = "訂單管理";
    ViewData["PageId"] = "admin-orders";

    ViewBag.CurrentPage = Model.CurrentPage;
    ViewBag.TotalPages = Model.TotalPages;
    ViewBag.HasPreviousPage = Model.HasPreviousPage;
    ViewBag.HasNextPage = Model.HasNextPage;
}

<div class="d-flex justify-content-between align-items-center mb-4">
        <h3>📦 訂單管理</h3>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">共 @Model.TotalCount 筆訂單</span>
            <a asp-action="ExportCsv" class="btn btn-outline-success btn-sm">
                <i class="bi bi-download me-1"></i>匯出 CSV
            </a>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">← 返回後台</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>訂單編號</th>
                    <th>會員</th>
                    <th>下單時間</th>
                    <th>總金額</th>
                    <th>付款方式</th>
                    <th>訂單狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Items)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>@order.UserEmail</td>
                        <td>@order.FormattedOrderDate</td>
                        <td>
                            @if (order.HasDiscount)
                            {
                                <span class="text-decoration-line-through text-muted small d-block">NT$ @order.FormattedTotalAmount</span>
                            }
                            <span>NT$ @order.FormattedFinalAmount</span>
                        </td>
                        <td>
                            <span class="badge @order.PaymentBadgeClass">
                                @order.PaymentMethodText
                            </span>
                        </td>
                        <td>
                            <span class="badge @order.StatusBadgeClass">
                                @order.StatusText
                            </span>
                        </td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary">查看</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" />
