@model IEnumerable<MusicShop.Service.ViewModels.Admin.SystemSettingListItemViewModel>
@{
    ViewData["Title"] = "系統參數管理";
    ViewData["PageId"] = "admin-system-settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-gear"></i> 系統參數管理</h3>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> 新增參數</a>
</div>

@{
    var grouped = Model.GroupBy(s => s.Group ?? "未分組").OrderBy(g => g.Key);
}

@foreach (var group in grouped)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-folder"></i> @group.Key</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Key</th>
                            <th>值</th>
                            <th>說明</th>
                            <th>類型</th>
                            <th>最後更新</th>
                            <th class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var setting in group)
                        {
                            <tr>
                                <td><code>@setting.Key</code></td>
                                <td>
                                    @if (setting.Value.Length > 50)
                                    {
                                        <span title="@setting.Value">@setting.Value.Substring(0, 50)...</span>
                                    }
                                    else
                                    {
                                        @setting.Value
                                    }
                                </td>
                                <td class="text-muted">@(setting.Description ?? "-")</td>
                                <td><span class="badge bg-secondary">@setting.ValueType</span></td>
                                <td>
                                    <small class="text-muted">@setting.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</small>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@setting.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> 編輯
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('確定要刪除參數「@setting.Key」嗎？')">
                                        <input type="hidden" name="id" value="@setting.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> 刪除
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle"></i> 尚未建立任何系統參數，請點擊「新增參數」開始設定。
    </div>
}

<div class="mt-3">
    <div class="alert alert-warning">
        <h6><i class="bi bi-exclamation-triangle"></i> 注意事項：</h6>
        <ul class="mb-0">
            <li>修改系統參數可能會影響網站運作，請謹慎操作</li>
            <li>參數 Key 建立後無法修改，請確認命名正確</li>
            <li>值類型僅作為參考標記，實際使用時需由程式碼進行型別轉換</li>
        </ul>
    </div>
</div>
