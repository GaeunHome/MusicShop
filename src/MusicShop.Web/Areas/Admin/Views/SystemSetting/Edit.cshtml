@model MusicShop.Service.ViewModels.Admin.SystemSettingFormViewModel
@{
    ViewData["Title"] = "編輯系統參數";
}

<div>
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> 返回列表</a>
        <h3 class="mb-0"><i class="bi bi-gear"></i> 編輯系統參數</h3>
    </div>

    <div class="col-md-6 col-lg-5">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

            <div class="mb-3">
                <label asp-for="Key" class="form-label fw-bold">參數 Key</label>
                <input asp-for="Key" class="form-control" readonly>
                <div class="form-text">參數 Key 建立後不可修改</div>
            </div>

            <div class="mb-3">
                <label asp-for="Value" class="form-label fw-bold">參數值 <span class="text-danger">*</span></label>
                <input asp-for="Value" class="form-control">
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">說明</label>
                <input asp-for="Description" class="form-control" placeholder="簡述此參數的用途">
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Group" class="form-label fw-bold">分組</label>
                <input asp-for="Group" class="form-control" placeholder="例如：網站設定、訂單設定、顯示設定"
                       list="groupSuggestions">
                <datalist id="groupSuggestions">
                    <option value="網站設定"></option>
                    <option value="訂單設定"></option>
                    <option value="顯示設定"></option>
                </datalist>
                <span asp-validation-for="Group" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ValueType" class="form-label fw-bold">值類型 <span class="text-danger">*</span></label>
                <select asp-for="ValueType" class="form-select">
                    <option value="string">string（文字）</option>
                    <option value="int">int（整數）</option>
                    <option value="decimal">decimal（小數）</option>
                    <option value="bool">bool（布林值）</option>
                </select>
                <span asp-validation-for="ValueType" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> 儲存</button>
                <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
            </div>
        </form>
    </div>
</div>
